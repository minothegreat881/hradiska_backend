{
  "kind": "collectionType",
  "collectionName": "blog_comments",
  "info": {
    "singularName": "blog-comment",
    "pluralName": "blog-comments",
    "displayName": "Blog Comment",
    "description": "Komentáre k blog článkom — public POST od návštevníkov, admin moderation pred zobrazením."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "authorName": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "authorEmail": {
      "type": "email"
    },
    "authorProfile": {
      "type": "string",
      "maxLength": 500
    },
    "content": {
      "type": "text",
      "required": true,
      "maxLength": 5000
    },
    "approved": {
      "type": "boolean",
      "default": false,
      "required": true
    },
    "likes": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "sourceBlogger": {
      "type": "boolean",
      "default": false
    },
    "sourceBloggerId": {
      "type": "string",
      "maxLength": 200
    },
    "originalDate": {
      "type": "datetime"
    },
    "inReplyTo": {
      "type": "string",
      "maxLength": 200
    },
    "post": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::blog-post.blog-post",
      "inversedBy": "comments"
    }
  }
}
