      {
        "id": "tag:blogger.com,1999:blog-6818054921907446479.post-2660537529142005504",
        "bloggerPostId": "2660537529142005504",
        "author": "Ján Vicen",
        "authorProfile": "https://www.blogger.com/profile/09150824559979335898",
        "published": "2017-09-21T15:34:24.545+02:00",
        "updated": "2017-09-21T15:34:24.545+02:00",
        "content": "V prípade záujmu o akejkoľvek návštevy hradísk v okolí Banskej Bystrice ma môžete kontaktovať- 0904 659 999, vicenjan7@gmail.com, pre zosúladenie si termínov, nakoľko po celý rok organizujem turistický program o.z.INVERZIA  SLOVENSKO, kde navštevujeme hrady - zrúcaniny , hradiská a vrcholy hôr. Ján Vicen",
        "inReplyToArticle": "http://www.hradiska.sk/2013/11/selce-hradok.html",
        "replyToBloggerId": null,
