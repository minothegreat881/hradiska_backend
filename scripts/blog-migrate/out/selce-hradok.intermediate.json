    "tags": [
      "Selce - Hrádok"
    ],
    "category": null,
    "location": null,
    "keyFacts": [
      {
        "label": "Poloha",
        "value": "Hradisko leží na pravom brehu Selčianskeho potoka v chotári obce, v nadmorskej výške 780 m.",
        "icon": "map"
      },
      {
        "label": "Geologický podklad",
        "value": "Hradisko je hrebeňová antiklinála utvorená z vápencovej skaly, ktorej steny sú 2 – 7 m vysoké, pokryté tenkou hlinitou pokrývkou.",
        "icon": "mountain"
      },
      {
        "label": "Opevnenie",
        "value": "Od juhovýchodu chránil dve malé plošiny na vrchole val, ktorý je dnes už len veľmi nevýrazný.",
        "icon": "shield"
      },
      {
        "label": "Záhadné jamy",
        "value": "V priestore hradiska sa nachádzajú dve niekoľko metrov hlboké a široké jamy s nejasným účelom; mohlo ísť napríklad o cisterny na vodu z modernej alebo staršej doby.",
        "icon": "water"
      },
      {
        "label": "Depot rímskych mincí",
        "value": "V 30. rokoch bol nájdený depot strieborných rímskych denárov viacerých cisárov (najmä Marca Aurelia) a dve strieborné spony; v roku 1999 pribudlo ďalších 6 kusov denárov z obdobia 117 – 195 n. l., ktoré publikovala Dr. Kolníková v roku 2001.",
        "icon": "crown"
      },
      {
        "label": "Osídlenie viacerých období",
        "value": "Výskum Dr. Karola Pietu (AVANS 1988) doložil osídlenie lužickou kultúrou (neskorá doba bronzová), púchovskou kultúrou (neskorá doba laténska), obdobím sťahovania národov a stredovekom.",
        "icon": "building"
      },
