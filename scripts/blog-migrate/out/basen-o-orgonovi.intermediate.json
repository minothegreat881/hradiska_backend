    "timeline": [
      {
        "year": "príchod vojska",
        "title": "Kríž alebo smrť",
        "description": "Do kraja prichádza vojsko s krížom a núti obyvateľov vzdať sa starej viery; kríž prijímajú všetci okrem Orgoňa Starého, ktorý zostáva dobre ukrytý.",
        "type": "event"
      },
      {
        "year": "kliatba",
        "title": "Orgoňova kliatba",
        "description": "Orgoň, druid slovanský, udrie rukou o drevo ako kladivom do klina a preklína boha Paroma za to, že dopustil zánik jeho chrámu.",
        "type": "event"
      },
      {
        "year": "úder hromu",
        "title": "Zmiznutie a uväznenie duše",
        "description": "Rozčúlený boh hromu Parom udrie hromom; po Orgoňovi nezostane ani stopa a jeho duša ostáva uväznená v kameni s podivnými runami na Orgoňovej kýčere.",
        "type": "event"
      }
    ],
    "quotes": [],
    "blocks": [
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Ale je krásny"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "ten národ Slovanský"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "čo prírodu vzýva"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "pod Tatrami býva."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "No zrazu, v diaľavách"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "vojsko sa blíži"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "z očí im srší strach"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "s Bohom na kríži."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "„No tak dievča, príjmi kríž"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "inak draho zaplatíš!"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Odhoď modlu do lesa!“"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "A dievčina prikyvuje "
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "o svoj život bojí sa."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Kríž prijali všetci"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "pobrali si veci"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "do doliny zišli"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "a z lesa odišli."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Všetci až na jedného,"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "dobre ukrytého,"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Orgoňa Starého."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "„Parom, ty boh nebeský,"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "prečo si to dopustil?"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Tvoj chrám zmenil sa v trosky."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Prečo si nás opustil?“"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Tresol rukou po dreve,"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "jak kladivom do klina."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "„Ja, Orgoň, druid Slovanský,"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "ja ťa Parom, preklínam!“"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "A jak dopovedal,"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "udrel doň hrom"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "To sa veru rozčúlil"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "boh hromu, Parom."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Ani stopa po ňom-"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "po rúchu či remeni."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Orgoňova duša-"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "vo väzení, v kameni."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Vo väzení v kameni"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "duša jeho stoná,"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "s podivnými runami"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "ktoré nik nezdolá."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Neobyčajný kameň"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "čo obyčajne vyzerá"
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "s podivnými runami "
              }
            ]
          }
        ]
      },
      {
        "__component": "content.image-block",
