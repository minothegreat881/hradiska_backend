          }
        },
        "alt": "2. vojenské mapovanie - máme tu latinskú podobu názvu a jeho maďarskú verziu",
        "caption": "2. vojenské mapovanie - máme tu latinskú podobu názvu a jeho maďarskú verziu",
        "position": "left",
        "showCaption": true,
        "width": "50",
        "aspectRatio": "auto",
        "rounded": true,
        "shadow": true
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Trosky hradu už nik viac neopravoval, naopak — v roku 1709 ho ešte dôkladnejšie rozrumili najprv kuruci a následne aj labanci, len aby z neho nemali úžitok tí druhí."
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
