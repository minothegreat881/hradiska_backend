                "children": [
                  {
                    "type": "text",
                    "text": "Steinhubel: Nitrianske kniežatstvo"
                  }
                ]
              }
            ]
          }
        ]
      },
      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "heading",
            "children": [
              {
                "type": "text",
                "text": "Túto knihu si môžete kúpiť priamo tu:\n \n \n \n"
