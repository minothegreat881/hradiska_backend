      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Toto hradisko má veľké genius loci a každému odporúčam jeho návštevu. Zatiaľ na ňom nie je umiestnená žiadna informačná tabuľa, avšak predpokladám, že naše OZ Hradiská v budúcnosti jednu vytvorí..."
              }
            ]
          }
        ]
