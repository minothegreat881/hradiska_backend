      },
      {
        "label": "Konštrukcia valov",
        "value": "Druhá sonda odkryla súvislú vrstvu uhlíkov a spáleného dreva, čo naznačuje valy z nasucho kladených kameňov s drevenou komorovou konštrukciou.",
        "icon": "book"
      },
      {
        "label": "Stopy rímskeho vplyvu",
        "value": "Črepový materiál získaný na Hrádku obsahuje popri prvkoch staršej fázy púchovskej kultúry aj prvky s možnosťou zaradenia do obdobia rímskych provincií.",
        "icon": "star"
      },
