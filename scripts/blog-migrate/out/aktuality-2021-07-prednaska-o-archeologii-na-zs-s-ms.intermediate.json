      {
        "__component": "content.rich-text",
        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Ak si myslíte, že by aj ZŠ, ktorú ste navštevovali, alebo do ktorej chodili či chodia vaše deti, mala záujem o takúto prednášku, informujte ich o nás a ak sa ozvú so záujmom, buď ja alebo ak to bude zo vzdialenejšieho regiónu, tak niektorý kolega aj u vás spraví prednášku."
              }
            ]
          }
        ]
      },
