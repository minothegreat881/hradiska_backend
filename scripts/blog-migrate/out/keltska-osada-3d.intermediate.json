        "body": [
          {
            "type": "paragraph",
            "children": [
              {
                "type": "text",
                "text": "Za odbornú pomoc ďakujeme archeológom Radovanovi Čambalovi a Branislavovi Kovárovi.\n \n "
              }
            ]
          }
        ]
