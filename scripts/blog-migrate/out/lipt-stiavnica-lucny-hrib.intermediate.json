            "anchorHref": "https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgOgEgAyXZH5dz_y7wiOCngtxmpe8yffBLQAlbrIVx9Lh0Zv0FFF30mNjbd4eAFC0nS7CIYNofQZnx5RNOmLfq2wW0c5OtIzJuJ483a_bZkrO6d-5zgbPjS7wgIy24_V-EtzLVerGgLS0o/s1600/L%25C2%25A3u%25CC%2588ny+hr%25C2%25B0b+od+Z.JPG",
            "displayedWidth": 320,
