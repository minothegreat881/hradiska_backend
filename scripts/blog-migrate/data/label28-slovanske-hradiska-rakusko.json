{"version":"1.0","encoding":"UTF-8","feed":{"xmlns":"http://www.w3.org/2005/Atom","xmlns$openSearch":"http://a9.com/-/spec/opensearchrss/1.0/","xmlns$blogger":"http://schemas.google.com/blogger/2008","xmlns$georss":"http://www.georss.org/georss","xmlns$gd":"http://schemas.google.com/g/2005","xmlns$thr":"http://purl.org/syndication/thread/1.0","id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479"},"updated":{"$t":"2026-07-13T13:58:16.769+02:00"},"category":[{"term":"Najvýznamnejšie hradiská"},{"term":"Menšie hradiská"},{"term":"Náboženstvo a Legendy"},{"term":"Kostoly z Veľkej Moravy"},{"term":"Všeobecne o hradiskách"},{"term":"Žilina - Závodie"},{"term":"3D Rekonštrukcie"},{"term":"A. Gašpar: ZBEROVÉ NÁLEZY PÚCHOVSKEJ KULTÚRY ZO STREDNÉHO POVAŽIA"},{"term":"Alexander Ruttkay:  O Svätoplukovi a Nitre"},{"term":"Anton Intibus 1855 o okolí Trnavy"},{"term":"Arkona (D)"},{"term":"Bavorský geograf – prvá písomná zmienka o Nitrianskych Slovenoch"},{"term":"Beckov (Slovanské Hradisko)"},{"term":"Belušské Slatiny - Hradisko"},{"term":"Blatnohrad  - Pribinovo sídlo v Panónii (H)"},{"term":"Bohatstvo Slovenov"},{"term":"Bohyňa Lada na hrade Lietava"},{"term":"Bojnice"},{"term":"Bojná"},{"term":"Bojová taktika Maďarov a iných kočovníkov"},{"term":"Bošáca - Srniansky Háj"},{"term":"Bratislava"},{"term":"Braunsberg - keltské hradisko"},{"term":"Brekov"},{"term":"Brodské - Veleš"},{"term":"Bronzový poklad"},{"term":"Bíňa"},{"term":"Břeclav - Pohansko (CZ)"},{"term":"Chotěbuz - Podobora (CZ)"},{"term":"Dejiny Slovenska"},{"term":"Detektorizmus"},{"term":"Detva - Kalamárka"},{"term":"Devín"},{"term":"Devín - kresba"},{"term":"Divinka - Veľký vrch v 9. storočí"},{"term":"Divinka pri Žiline"},{"term":"Divinka pri Žiline (Veľký vrch)"},{"term":"Dolná Mariková - Hradisko Široká"},{"term":"Dolná Mariková – Šimunky"},{"term":"Dolné Orešany - Vápenice (alebo ako sme našli nové hradisko)"},{"term":"Dolné Vestenice"},{"term":"Domy Slovenov"},{"term":"Dražovce"},{"term":"Dreveník"},{"te