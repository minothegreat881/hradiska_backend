uoAVrX4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY/s220/SH+Kruh+s+dlznom1.JPG"}}],"generator":{"version":"7.00","uri":"http://www.blogger.com","$t":"Blogger"},"openSearch$startIndex":{"$t":"1"},"openSearch$itemsPerPage":{"$t":"25"},"entry":[{"id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479.post-8500187863760445040"},"published":{"$t":"2026-02-22T23:58:00.004+01:00"},"updated":{"$t":"2026-02-23T08:49:55.884+01:00"},"title":{"type":"text","$t":"ZÁKLADNÉ ZÁSADY OBČIANSKEHO ZDRUŽENIA HRADISKÁ"},"content":{"type":"html","$t":"<div style=\"text-align: justify;\">Občianske združenie Hradiská (ďalej len \"združenie\"), je predovšetkým spoločenstvom dobrovoľníkov so záujmom o históriu, archeológiu a ochranu kultúrneho dedičstva. Našou prioritou nie je detektorovanie ako také, ale systematická, zodpovedná a odborná práca v prospech poznania a ochrany historických lokalít.</div><p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: &quot;Times New Roman&quot;,&quot;serif&quot;; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\"></span></p><div class=\"separator\" style=\"clear: both; text-align: center;\"><a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhGz-OTyyds_WKYfEaLtmpHCT_ZpfQzoGwwzqeEDnVpkj9gDyZV5FAxzceTkrTPUKUJ9ZiuAztUJJdfyjYjdEK8Zv9B5M9G-atj2ForoskvcsiqVhsvTr1tmgruWDezKYHo06GfMEFDkCrGLnkVBSF85VkZtFGLrU6M1BKg_zFjOqYjo3C1JM7cpH9wwAtA/s960/Hradiska%20logo.jpg\" style=\"margin-left: 1em; margin-right: 1em;\"><img border=\"0\" data-original-height=\"937\" data-original-width=\"960\" height=\"312\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhGz-OTyyds_WKYfEaLtmpHCT_ZpfQzoGwwzqeEDnVpkj9gDyZV5FAxzceTkrTPUKUJ9ZiuAztUJJdfyjYjdEK8Zv9B5M9G-atj2ForoskvcsiqVhsvTr1tmgruWDezKYHo06GfMEFDkCrGLnkVBSF85VkZtFGLrU6M1BKg_zFjOqYjo3C1JM7cpH9wwAtA/s320/Hradiska%20logo.jpg\" width=\"320\" /></a></div><br />&nbsp;<p></p>\n\n<p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: &quot;Times New Roman&quot;,&quot;serif&quot;; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">&nbsp;</span></p><h2 align=\"center\" style=\"line-height: normal; margin-bottom: .0001pt; margin: 0cm; mso-hyphenate: none; mso-list: l0 level2 lfo5; mso-pagination: widow-orphan; punctuation-wrap: simple; tab-stops: list 0cm; text-align: center; text-autospace: ideograph-numeric; text-indent: 0cm; vertical-align: baseline;\"><span style=\"font-family: times;\"><span color=\"windowtext\" style=\"font-size: 12pt;\">1. Poslanie a ciele\nzdruženia</span><span style=\"color: black; font-size: 12pt;\">&nbsp;</span></span></h2>\n\n<p class=\"MsoBodyText\" style=\"margin-left: 36pt; mso-list: l1 level1 lfo6; tab-stops: list 36.0pt; text-align: justify; text-indent: -18pt;\"><span style=\"font-family: times;\"><span style=\"color: #333333; font-size: 12pt;\"><span style=\"mso-list: Ignore;\">1.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span><span style=\"color: black; font-size: 12pt;\">Základným cieľom združenia je, v&nbsp;súlade\nso Stanovami združenia, zbierať vedomosti a informácie o hradiskách na\nSlovensku, zverejňovať ich, napomáhať tak informovanosti verejnosti, rozvoju\nturizmu na hradištné lokality a tiež jeho usmerneniu, a zároveň pútavou formou\nzáujemcom priblížiť nesmierne bohaté obdobie našich národných dejín - včasný\nstredovek, najmä v časoch Veľkej Moravy. Cieľom združenia je tiež spoznávať\nnajstaršie dejiny<span style=\"mso-spacerun: yes;\">&nbsp; </span>Slovenska so zameraním\nna hradiská Slovanov, Keltov a starších kultúr, ktoré obývali v minulosti\núzemie Slovenska. </span><span style=\"color: #333333; font-size: 12pt;\"><span style=\"mso-spacerun: yes;\">&nbsp;</span>Združenie preto finančne podporuje autorov\npopulárno náučných článkov o hradiskách na Slovensku.</span></span></p>\n\n<p class=\"MsoBodyText\" style=\"margin-left: 36pt; mso-list: l1 level1 lfo6; tab-stops: list 36.0pt; text-align: justify; text-indent: -18pt;\"><span style=\"font-family: times;\"><span style=\"color: black; font-size: 12pt;\"><span style=\"mso-list: Ignore;\">2.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span><span style=\"color: black; font-size: 12pt;\">V súlade so základným cieľom sa združenie\nzameriava na znovuobjavovanie starých hradísk na Slovensku v očiach verejnosti.\nZa týmto účelom združenie spolupracuje s webovým portálom </span><span style=\"font-size: 12pt;\"><a href=\"http://www.hradiska.sk/\">www.hradiska.sk</a><span style=\"color: black;\">. Združenie ďalej v rámci svojich finančných možností\nzabezpečuje výrobu informačných tabúľ o jednotlivých hradiskách na Slovensku a\nich umiestňovanie v teréne, kde takéto informácie absentujú.</span></span></span></p>\n\n<p class=\"MsoBodyText\" style=\"margin-left: 36pt; mso-list: l1 level1 lfo6; tab-stops: list 36.0pt; text-align: justify; text-indent: -18pt;\"><span style=\"font-family: times;\"><span style=\"color: black; font-size: 12pt;\"><span style=\"mso-list: Ignore;\">3.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span><span style=\"color: black; font-size: 12pt;\">Združenie zabezpečuje tiež finančnú a\nmediálnu podporu umeleckej činnosti (obrazové, audiovizuálne a iné diela),\nktorých predmetom sú hradiská na slovensku a dejiny Slovanov a Keltov na našom\núzemí.</span></span></p>\n\n<p class=\"MsoBodyText\" style=\"margin-left: 36pt; mso-list: l1 level1 lfo6; tab-stops: list 36.0pt; text-align: justify; text-indent: -18pt;\"><span style=\"font-family: times;\"><span style=\"color: black; font-size: 12pt;\"><span style=\"mso-list: Ignore;\">4.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span><span style=\"color: black; font-size: 12pt;\">Ďalším cieľom je združovať jednotlivcov so\nzáujmom o najstaršie dejiny Slovenska a aktivizovať ich tvorivú činnosť v&nbsp;\noblastiach načrtnutých v bode 3.</span></span></p>\n\n<p class=\"MsoBodyText\" style=\"margin-left: 36pt; mso-list: l1 level1 lfo6; tab-stops: list 36.0pt; text-align: justify; text-indent: -18pt;\"><span style=\"font-family: times;\"><span style=\"color: black; font-size: 12pt;\"><span style=\"mso-list: Ignore;\">5.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span><span style=\"color: black; font-size: 12pt;\">V neposlednom rade je cieľom tiež\nspolupracovať s&nbsp;kultúrnymi, prípadne inými orgánmi a&nbsp;organizáciami a\nobčianskymi združeniami v&nbsp;oblasti dejín a viery Slovanov a Keltov</span></span></p>\n\n<p class=\"MsoBodyText\" style=\"margin-left: 36pt; mso-list: l1 level1 lfo6; tab-stops: list 36.0pt; text-align: justify; text-indent: -18pt;\"><span style=\"font-family: times;\"><span style=\"color: black; font-size: 12pt;\"><span style=\"mso-list: Ignore;\">6.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp; </span></span></span><span style=\"color: black; font-size: 12pt;\">OZH tiež spolupracuje s odbornou a laickou\nverejnosťou pri napĺňaní cieľov občianskeho združenia</span></span></p>\n\n<p class=\"MsoBodyText\" style=\"margin-left: 36pt; mso-list: l1 level1 lfo6; tab-stops: list 36.0pt; text-align: justify; text-indent: -18pt;\"><span style=\"font-family: times;\"><b style=\"mso-bidi-font-weight: normal;\"><span style=\"color: black; font-size: 12pt;\"><span style=\"mso-list: Ignore;\">7.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp;\n</span></span></span></b><span style=\"color: black; font-size: 12pt;\">Medzi\nčinnosti združenia patrí tiež účasť na oficiálnych archeologických výskumoch s&nbsp;použitím\ndetektorov kovov. </span><b style=\"mso-bidi-font-weight: normal;\"><span style=\"font-size: 12pt; mso-fareast-language: SK;\">Detektorovanie je iba jednou z\nmožných foriem spolupráce a vždy prebieha výlučne v rámci zákonných pravidiel,\nmetodiky a konkrétnych povolení.</span></b><b style=\"mso-bidi-font-weight: normal;\"><span style=\"color: black; font-size: 12pt;\"> </span></b></span></p>\n\n<p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">&nbsp;</span></p>\n\n<p align=\"center\" class=\"MsoNormal\" style=\"line-height: normal; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; text-align: center;\"><span style=\"font-family: times;\"><b><span style=\"font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">2. Spolupráca s archeológmi</span></b><span style=\"font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\"></span></span></p>\n\n<p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">Spolupráca v\noblasti terénneho výskumu prebieha výhradne:</span></p>\n\n<ul type=\"disc\"><li class=\"MsoNormal\" style=\"line-height: normal; mso-list: l5 level1 lfo1; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; tab-stops: list 36.0pt; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">pod\n     vedením oprávnených archeológov,</span></li><li class=\"MsoNormal\" style=\"line-height: normal; mso-list: l5 level1 lfo1; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; tab-stops: list 36.0pt; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">na\n     základe riadnych povolení,</span></li><li class=\"MsoNormal\" style=\"line-height: normal; mso-list: l5 level1 lfo1; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; tab-stops: list 36.0pt; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">podľa\n     prísne stanovenej metodiky.</span></li></ul><p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">&nbsp;</span></p>\n\n<p align=\"center\" class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: center;\"><b style=\"mso-bidi-font-weight: normal;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">3. Zákaz detektorovania bez súhlasu a&nbsp;vedomosti\narcheológa</span></b></p>\n\n<p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">&nbsp;</span></p>\n\n<p class=\"MsoListParagraphCxSpFirst\" style=\"line-height: normal; margin-bottom: 0cm; margin-left: 90.0pt; margin-right: 0cm; margin-top: 0cm; margin: 0cm 0cm 0cm 90pt; mso-add-space: auto; mso-list: l5 level2 lfo1; text-align: justify; text-indent: -36pt;\"><span style=\"font-family: times;\"><span style=\"font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;;\"><span style=\"mso-list: Ignore;\">I.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\n</span></span></span><span style=\"font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">Občianske združenie\n<b style=\"mso-bidi-font-weight: normal;\">Hradiská nie je platformou na\nzastrešovanie individuálneho hľadania ani na legalizáciu súkromných aktivít v&nbsp;teréne bez povolenia</b>\n(ďalej len hľadanie „na vlastnú päsť“). </span><span style=\"font-size: 12pt;\"></span></span></p>\n\n<p class=\"MsoListParagraphCxSpMiddle\" style=\"line-height: normal; margin-bottom: 0cm; margin-left: 90.0pt; margin-right: 0cm; margin-top: 0cm; margin: 0cm 0cm 0cm 90pt; mso-add-space: auto; mso-list: l5 level2 lfo1; text-align: justify; text-indent: -36pt;\"><span style=\"font-family: times;\"><span style=\"font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;;\"><span style=\"mso-list: Ignore;\">II.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\n</span></span></span><span style=\"font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">Člen\nzdruženia berie na vedomie, že <b style=\"mso-bidi-font-weight: normal;\">vyhľadávanie\narcheologických nálezov bez povolenia príslušného pamiatkového úradu je\nnelegálnou činnosťou</b> a&nbsp;že sa s&nbsp;ňou môže dopustiť priestupku na\núseku ochrany archeologického dedičstva, alebo trestného činu poškodzovanie a&nbsp;znehodnocovanie\narcheologického dedičstva podľa § 249 Trestného zákona.</span><span style=\"font-size: 12pt;\"></span></span></p>\n\n<p class=\"MsoListParagraphCxSpMiddle\" style=\"line-height: normal; margin-bottom: 0cm; margin-left: 90.0pt; margin-right: 0cm; margin-top: 0cm; margin: 0cm 0cm 0cm 90pt; mso-add-space: auto; mso-list: l5 level2 lfo1; text-align: justify; text-indent: -36pt;\"><span style=\"font-family: times;\"><b style=\"mso-bidi-font-weight: normal;\"><span style=\"font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;;\"><span style=\"mso-list: Ignore;\">III.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\n</span></span></span></b><b style=\"mso-bidi-font-weight: normal;\"><span style=\"font-size: 12pt;\">Člen združenia sa\nzaručuje, že nebude hľadať s detektorom kovov na vlastnú päsť bez vedomia archeológov a&nbsp;ostatných\nčlenov združenia. </span></b></span></p>\n\n<p class=\"MsoListParagraphCxSpMiddle\" style=\"line-height: normal; margin-bottom: 0cm; margin-left: 90.0pt; margin-right: 0cm; margin-top: 0cm; margin: 0cm 0cm 0cm 90pt; mso-add-space: auto; mso-list: l5 level2 lfo1; text-align: justify; text-indent: -36pt;\"><span style=\"font-family: times;\"><b style=\"mso-bidi-font-weight: normal;\"><span style=\"font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;;\"><span style=\"mso-list: Ignore;\">IV.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\n</span></span></span></b><span style=\"font-size: 12pt;\">V&nbsp;prípade ak člen poruší vyššie uvedené\npravidlo, <b style=\"mso-bidi-font-weight: normal;\">bude za to vylúčený zo\nzdruženia. </b></span></span></p>\n\n<p class=\"MsoListParagraphCxSpLast\" style=\"line-height: normal; margin-bottom: 0cm; margin-left: 90.0pt; margin-right: 0cm; margin-top: 0cm; margin: 0cm 0cm 0cm 90pt; mso-add-space: auto; mso-list: l5 level2 lfo1; text-align: justify; text-indent: -36pt;\"><span style=\"font-family: times;\"><span style=\"font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;;\"><span style=\"mso-list: Ignore;\">V.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;\n</span></span></span><span style=\"font-size: 12pt;\">Združenie\nnepreberá ochranu ani&nbsp;záruku za nikoho, kto vyhľadáva s&nbsp;detektorom kovov\nbez povolenia archeológa resp. príslušného pamiatkového úradu. <b style=\"mso-bidi-font-weight: normal;\">Členstvo v združení v žiadnom prípade nie\nje poľahčujúcou okolnosťou v prípade porušenia tohto pravidla</b>, resp. v&nbsp;prípade\nporušenia zákona. Skôr naopak, združenie v&nbsp;takom prípade poskytne orgánom\nčinným v&nbsp;trestnom konaní úplnú súčinnosť pri vyšetrovaní bývalého člena\nzdruženia.</span></span></p>\n\n<p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt;\">&nbsp;</span></p>\n\n<p align=\"center\" class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: center;\"><b><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">4. Podmienky členstva</span></b></p>\n\n<p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">&nbsp;</span></p>\n\n<p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">Členstvo v\nzdružení nie je formalitou. Vyžaduje:</span></p>\n\n<ul type=\"disc\"><li class=\"MsoNormal\" style=\"line-height: normal; mso-list: l3 level1 lfo2; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; tab-stops: list 36.0pt; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">seriózny\n     záujem o históriu a ochranu pamiatok,</span></li><li class=\"MsoNormal\" style=\"line-height: normal; mso-list: l3 level1 lfo2; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; tab-stops: list 36.0pt; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">ochotu\n     podieľať sa na rôznorodej dobrovoľníckej činnosti, nie len na\n     detektorovaní</span></li><li class=\"MsoNormal\" style=\"line-height: normal; mso-list: l3 level1 lfo2; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; tab-stops: list 36.0pt; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">rešpektovanie\n     zákonných a etických pravidiel,</span></li><li class=\"MsoNormal\" style=\"line-height: normal; mso-list: l3 level1 lfo2; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; tab-stops: list 36.0pt; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">preukázateľnú\n     a dlhodobú spoluprácu so združením.</span></li></ul>\n\n<p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: times;\"><b style=\"mso-bidi-font-weight: normal;\"><span style=\"font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">Ak je záujemca primárne detektorista</span></b><span style=\"font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">, základnou podmienkou ďalšej\nspolupráce je:</span></span></p>\n\n<ul type=\"disc\"><li class=\"MsoNormal\" style=\"line-height: normal; mso-list: l4 level1 lfo3; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; tab-stops: list 36.0pt; text-align: justify;\"><b style=\"mso-bidi-font-weight: normal;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">vysporiadanie sa so všetkými\n     nelegálne nájdenými archeologickými predmetmi ich riadnym odovzdaním\n     oprávneným archeológom,</span></b></li><li class=\"MsoNormal\" style=\"line-height: normal; mso-list: l4 level1 lfo3; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; tab-stops: list 36.0pt; text-align: justify;\"><b style=\"mso-bidi-font-weight: normal;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">záväzok, že nebude vykonávať\n     individuálne hľadanie na vlastnú päsť.</span></b></li></ul>\n\n<p align=\"center\" class=\"MsoNormal\" style=\"line-height: normal; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; text-align: center;\"><b style=\"mso-bidi-font-weight: normal;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">5. Mlčanlivosť</span></b></p>\n\n<ol start=\"1\" type=\"1\"><li class=\"MsoNormal\" style=\"line-height: normal; mso-list: l2 level1 lfo4; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; tab-stops: list 36.0pt; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">Informácie\n     o lokalitách a výskumoch, ktoré sa dozvieme v združení, sa považujú za\n     utajené, pokiaľ sa členovia v skupine nedohodnú (väčšinou po porade s&nbsp;archeológmi),\n     že informácia môže byť zverejnená. Členovia preto <b style=\"mso-bidi-font-weight: normal;\">nebudú zverejňovať najmä na sociálnych sieťach informácie o&nbsp;prebiehajúcich\n     výskumoch</b>.</span></li><li class=\"MsoNormal\" style=\"line-height: normal; mso-list: l2 level1 lfo4; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; tab-stops: list 36.0pt; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">Rovnako\n     platí pravidlo, že <b style=\"mso-bidi-font-weight: normal;\">nálezy z\n     výskumov</b>, ktoré sú prístupné pre členov združenia, <b style=\"mso-bidi-font-weight: normal;\">sa nesmú bez povolenia archeol</b>ogov\n     a bez predchádzajúcej dohody s&nbsp;archeológmi <b style=\"mso-bidi-font-weight: normal;\">nikde verejne publikovať</b> a posúvať mimo združenia.</span></li></ol>\n\n<p align=\"center\" class=\"MsoNormal\" style=\"line-height: normal; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; mso-outline-level: 5; text-align: center;\"><b><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">&nbsp;</span></b></p>\n\n<p align=\"center\" class=\"MsoNormal\" style=\"line-height: normal; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; mso-outline-level: 5; text-align: center;\"><b><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">6. Kapacitné možnosti</span></b></p>\n\n<p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">V súčasnosti\nzdruženie nemá voľné kapacity na systematické zaškoľovanie a garantovanie činnosti\nnových členov. Spolupráca je možná najmä postupným zapojením sa do konkrétnych\naktivít a výskumov, kde sa môžeme osobne spoznať a posúdiť možnosti ďalšieho\npôsobenia.</span></p>\n\n<p align=\"center\" class=\"MsoNormal\" style=\"line-height: normal; mso-margin-bottom-alt: auto; mso-margin-top-alt: auto; mso-outline-level: 5; text-align: center;\"><b><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">7. Alternatívy pre záujemcov o\ndetektorovanie</span></b></p>\n\n<p class=\"MsoNormal\" style=\"line-height: normal; margin-bottom: 0cm; text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; mso-fareast-font-family: &quot;Times New Roman&quot;; mso-fareast-language: SK;\">Ak niekoho\nzaujíma výhradne detektorovanie, odporúčame obrátiť sa priamo na príslušný krajský pamiatkový úrad a informovať sa o možnostiach legálneho dobrovoľníctva\nv rámci oficiálnych projektov. Našou ambíciou je budovať komunitu ľudí, ktorí\nchápu hodnotu archeologického dedičstva, pristupujú k nemu s rešpektom a sú\npripravení investovať svoj čas a energiu do zmysluplnej dobrovoľníckej práce –\nnielen do hľadania nálezov, ale do ich ochrany, výskumu a prezentácie\nverejnosti.</span></p>\n\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; line-height: 115%;\">&nbsp;</span></p>\n\n<p align=\"center\" class=\"MsoListParagraph\" style=\"mso-list: l1 level1 lfo6; tab-stops: list 36.0pt; text-align: center; text-indent: -18pt;\"><span style=\"font-family: times;\"><b style=\"mso-bidi-font-weight: normal;\"><span style=\"font-size: 12pt; line-height: 115%; mso-fareast-font-family: &quot;Times New Roman&quot;;\"><span style=\"mso-list: Ignore;\">8.<span style=\"font-feature-settings: normal; font-kerning: auto; font-language-override: normal; font-optical-sizing: auto; font-size-adjust: none; font-size: 7pt; font-stretch: normal; font-style: normal; font-variant: normal; font-variation-settings: normal; font-weight: normal; line-height: normal;\">&nbsp;&nbsp;&nbsp;&nbsp;\n</span></span></span></b><b style=\"mso-bidi-font-weight: normal;\"><span style=\"font-size: 12pt; line-height: 115%;\">Detektorovnie s nami bez členstva v&nbsp;OZ Hradiská</span></b></span></p>\n\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-family: times; font-size: 12pt; line-height: 115%;\">Ak máte záujem výhradne\no&nbsp;detektorovanie s nami na archeologických výskumoch, ale nie ste členom OZ\nHradiská, môžete sa ozvať na e-mailovej adrese <a href=\"mailto:hradiska333@gmail.com\"><span style=\"mso-ansi-language: SK; mso-bidi-language: AR-SA; mso-fareast-language: EN-US;\">hradiska333@gmail.com</span></a>,\nako záujemca o&nbsp;výpomoc na výskumoch, a&nbsp;v&nbsp;takom prípade Vám v&nbsp;niektorých\nprípadoch (po predchádzajúcej dohode s archeológom) oznámime termín a&nbsp;lokalitu vykonávaného výskumu a&nbsp;kontaktný\núdaj na organizátora. Za pomocníkov, ktorí nie sú členmi združenia nepreberá\nzdruženie žiadnu zodpovednosť. </span></p>\n\n"},"link":[{"rel":"replies","type":"application/atom+xml","href":"http://www.hradiska.sk/feeds/8500187863760445040/comments/default","title":"Zverejniť komentáre"},{"rel":"replies","type":"text/html","href":"http://www.hradiska.sk/2026/02/zakladne-zasady-obcianskeho-zdruzenia.html#comment-form","title":"0 komentárov"},{"rel":"edit","type":"application/atom+xml","href":"http://www.blogger.com/feeds/6818054921907446479/posts/default/8500187863760445040"},{"rel":"self","type":"application/atom+xml","href":"http://www.blogger.com/feeds/6818054921907446479/posts/default/8500187863760445040"},{"rel":"alternate","type":"text/html","href":"http://www.hradiska.sk/2026/02/zakladne-zasady-obcianskeho-zdruzenia.html","title":"ZÁKLADNÉ ZÁSADY OBČIANSKEHO ZDRUŽENIA HRADISKÁ"}],"author":[{"name":{"$t":"Orgon"},"uri":{"$t":"http://www.blogger.com/profile/01396912608531297025"},"email":{"$t":"noreply@blogger.com"},"gd$image":{"rel":"http://schemas.google.com/g/2005#thumbnail","width":"32","height":"32","src":"//blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjRf79q2mlg3o6hsyWbYMCCgv1WaA6pM0mtkWB0QdJ76W64emXoS0lwpSlUw9K5iinuoAVrX4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY/s220/SH+Kruh+s+dlznom1.JPG"}}],"media$thumbnail":{"xmlns$media":"http://search.yahoo.com/mrss/","url":"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhGz-OTyyds_WKYfEaLtmpHCT_ZpfQzoGwwzqeEDnVpkj9gDyZV5FAxzceTkrTPUKUJ9ZiuAztUJJdfyjYjdEK8Zv9B5M9G-atj2ForoskvcsiqVhsvTr1tmgruWDezKYHo06GfMEFDkCrGLnkVBSF85VkZtFGLrU6M1BKg_zFjOqYjo3C1JM7cpH9wwAtA/s72-c/Hradiska%20logo.jpg","height":"72","width":"72"},"thr$total":{"$t":"0"}}]}}