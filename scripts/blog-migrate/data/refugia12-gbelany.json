kWB0QdJ76W64emXoS0lwpSlUw9K5iinuoAVrX4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY\/s220\/SH+Kruh+s+dlznom1.JPG"}}],"generator":{"version":"7.00","uri":"http://www.blogger.com","$t":"Blogger"},"openSearch$totalResults":{"$t":"1"},"openSearch$startIndex":{"$t":"1"},"openSearch$itemsPerPage":{"$t":"5"},"entry":[{"id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479.post-8462600986895280963"},"published":{"$t":"2013-05-07T18:08:00.002+02:00"},"updated":{"$t":"2013-06-02T21:43:32.396+02:00"},"category":[{"scheme":"http://www.blogger.com/atom/ns#","term":"Gbeľany"}],"title":{"type":"text","$t":"Gbeľany"},"content":{"type":"html","$t":"\u003Cdiv style=\"text-align: justify;\"\u003E\nHradisko Gbeľany patrí medzi sídliská vybudované ľudom púchovskej kultúry koncom 1. stor. pred n. 1.  a neskôr bolo zrejme využívané aj slovanmi ešte z pred-veľkomoravskej doby, ktorí sídelne nadväzujú na predchádzajúce obdobia. Na roliach na západnom okraji obce sa v roku 1963 našli veľkomoravské črepy.\u0026nbsp;\u003C\/div\u003E\n\u003Cdiv\u003E\n\u003Cdiv\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjgsD9MPaY9OEdI2f9QOUS1iF8rK5z8SnwU1AHWHivQmqQ33jwTb59Lw6njXyN9Vl9aRxfbmFPqzMNHc9R69dXMdi6sSIWM-gKa0TDZ-PXHBNtZpeQLyRHI6WXpwTEs5-_Q0JXJRDKvqXM\/s1600\/mapa.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"187\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjgsD9MPaY9OEdI2f9QOUS1iF8rK5z8SnwU1AHWHivQmqQ33jwTb59Lw6njXyN9Vl9aRxfbmFPqzMNHc9R69dXMdi6sSIWM-gKa0TDZ-PXHBNtZpeQLyRHI6WXpwTEs5-_Q0JXJRDKvqXM\/s320\/mapa.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\nHradisko sa nachádza \u0026nbsp;na SV asi 2 km od obce vo výške 652 mnm. Chrbát hradiska sa tiahne zo severu na juh a má dva hlavné vrcholy – plošiny v tvare nepravidelného oválu. \u0026nbsp;Dĺžka S-J smeru je 60 m, V-Z smeru je len 30 metrov. Celková plocha je 0,16 ha. Cesta vedie stúpaním hradného kopca po jeho južnom a východnom svahu. Vchod \u0026nbsp;do hradiska vybudovali na juhovýchodnej strane. Na okraji plošiny kopca je možné sledovať pôdorys bývalého valu alebo múru.\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgzrDtFJTDGVH3iVplKzjd6FEYxacWsfOlHCPjF_c-HAWEI1hJfo1wX1s0H4PxQPcTLL0X5ZMgG9LjI7inKsiZOz16_cbrq2A0QbYawQsCYfGHCOXqFtgzQJMCmaPh1N8Ne568TMIcqIpk\/s1600\/mapa.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"320\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgzrDtFJTDGVH3iVplKzjd6FEYxacWsfOlHCPjF_c-HAWEI1hJfo1wX1s0H4PxQPcTLL0X5ZMgG9LjI7inKsiZOz16_cbrq2A0QbYawQsCYfGHCOXqFtgzQJMCmaPh1N8Ne568TMIcqIpk\/s320\/mapa.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\nDruhá časť hradu je situovaná na severnom cípe 75 m na sever a má tvar menšieho \u0026nbsp;lichobežníka. Rozmery sú vo východo-západnom smere 24 m, v smere sever-juh 14 metrov. Táto časť hradiska je viditeľne obohnaná valmi a priekopou, pôvodne asi aj palisádovým opevnením. Pre dobré dochovanie valov a priekopy je možné súdiť, že sa jedná o mladšiu časť hradiska. Stavebné zvyšky na povrchu nemožno rozpoznať.\u003C\/div\u003E\n\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiAf-3120H76LcUblocHAgAGjjCg__hv4O8lbpu2nwIgiKC-g5IuIr4IvP7wCNGm4qOvL4XWvpt8keNTvKkuGOPpLG86auA_cP9FTAYPVN9Xb2Ea290ADZuJ0cOdbVf2gLExQwmG_NgMik\/s1600\/Lu%CC%81ka+na+u%CC%81boc%CC%8Ci%CC%81+hradiska+je+strma%CC%81,+a+poskytuje+kra%CC%81sne+vy%CC%81hl%CC%8Cady,+Uprostred+je+bra%CC%81na+do+Turc%CC%8Cianskej+kotliny+a+hrad+Strec%CC%8Cno..jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" height=\"95\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiAf-3120H76LcUblocHAgAGjjCg__hv4O8lbpu2nwIgiKC-g5IuIr4IvP7wCNGm4qOvL4XWvpt8keNTvKkuGOPpLG86auA_cP9FTAYPVN9Xb2Ea290ADZuJ0cOdbVf2gLExQwmG_NgMik\/s320\/Lu%CC%81ka+na+u%CC%81boc%CC%8Ci%CC%81+hradiska+je+strma%CC%81,+a+poskytuje+kra%CC%81sne+vy%CC%81hl%CC%8Cady,+Uprostred+je+bra%CC%81na+do+Turc%CC%8Cianskej+kotliny+a+hrad+Strec%CC%8Cno..jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003ELúka na úbočí hradiska je strmá, a poskytuje krásne výhľady, Uprostred je brána do Turčianskej kotliny a hrad Strečno\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhvjqbokXPpS5AHEd1EyA0b7jN6XZArTZwsg5HUxYhBgcRX7xMliU3gcjztyE5Ofe2YuuZc73Y5iRfhU7qV3J-yhXxckcczziKcqvgMMCLM-_fpMgZLiQDPZhJUyjcbud165hfUCWFgAtc\/s1600\/Vy%CC%81hl%CC%8Cad+na+hradisko+Strani%CC%81k,+cestou+dolu+z+Hradiska+Gbel%CC%8Cany.+Vpravo+Hra%CC%81dok.+Dokonala%CC%81+trojica.+.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" height=\"102\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhvjqbokXPpS5AHEd1EyA0b7jN6XZArTZwsg5HUxYhBgcRX7xMliU3gcjztyE5Ofe2YuuZc73Y5iRfhU7qV3J-yhXxckcczziKcqvgMMCLM-_fpMgZLiQDPZhJUyjcbud165hfUCWFgAtc\/s320\/Vy%CC%81hl%CC%8Cad+na+hradisko+Strani%CC%81k,+cestou+dolu+z+Hradiska+Gbel%CC%8Cany.+Vpravo+Hra%CC%81dok.+Dokonala%CC%81+trojica.+.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EVýhľad na hradisko Straník, cestou dolu z Hradiska Gbeľany. Vpravo Hrádok. Dokonalá trojica\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiX093ahriTi3ul0ON1iWGoDbSrlKuVkCYr-ZlZG5-PEGA-LtXAUHiZrROTnNIGSQE8IRvUuAUbTHhKtfz0d4uPY4RMCUEdG1DS_GzC1vafjuqraiRubGUKaxGkDjPsaRTsRmonToefNXE\/s1600\/Hradisko+ma%CC%81+strme%CC%81+svahy.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" height=\"107\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiX093ahriTi3ul0ON1iWGoDbSrlKuVkCYr-ZlZG5-PEGA-LtXAUHiZrROTnNIGSQE8IRvUuAUbTHhKtfz0d4uPY4RMCUEdG1DS_GzC1vafjuqraiRubGUKaxGkDjPsaRTsRmonToefNXE\/s320\/Hradisko+ma%CC%81+strme%CC%81+svahy.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EHradisko má strmé svahy\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjEZezxE6A_-7dNRx9m3u6Fan82NHe10uLl04mSg0LO5xmjjY0O2Xn-AolhW5Yf8zQ51c060rw_-J9QUE-xokMdMHEob2td8xKVo8kLbQmHEam6sEpYTrMXOuBmFEERa6_9KUdPd8i-J30\/s1600\/Na+plos%CC%8Cine+hradiska+je+vidiet%CC%8C+valy,+a+pri%CC%81stupove+cesty..jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" height=\"180\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjEZezxE6A_-7dNRx9m3u6Fan82NHe10uLl04mSg0LO5xmjjY0O2Xn-AolhW5Yf8zQ51c060rw_-J9QUE-xokMdMHEob2td8xKVo8kLbQmHEam6sEpYTrMXOuBmFEERa6_9KUdPd8i-J30\/s320\/Na+plos%CC%8Cine+hradiska+je+vidiet%CC%8C+valy,+a+pri%CC%81stupove+cesty..jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003ENa plošine hradiska je vidieť valy, a prístupove cesty\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjB9KKlYsoPIZ6sRXMrGHJ_fU4w7BjYb0iy7RkUBXtk7bD6pOsWWJCGunV6wptJh176acqbg6XuPH8PGA-hIW04MStAJmJuvQhi57cvKBZ2Rr65R8oJXikM-ksKL24J7QtflEJqgjIgDnk\/s1600\/Pohl%CC%8Cad+z+hornej+c%CC%8Casti+hradiska+na+dolnu%CC%81+c%CC%8Cast%CC%8C.+Vpravo+sa+nacha%CC%81dzal+pravdepodobne+opevneny%CC%81+vel%CC%8Cmoz%CC%8Cov+dvorec+s+viditel%CC%8Cny%CC%81mi+priekopami+a+valmi..jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" height=\"180\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjB9KKlYsoPIZ6sRXMrGHJ_fU4w7BjYb0iy7RkUBXtk7bD6pOsWWJCGunV6wptJh176acqbg6XuPH8PGA-hIW04MStAJmJuvQhi57cvKBZ2Rr65R8oJXikM-ksKL24J7QtflEJqgjIgDnk\/s320\/Pohl%CC%8Cad+z+hornej+c%CC%8Casti+hradiska+na+dolnu%CC%81+c%CC%8Cast%CC%8C.+Vpravo+sa+nacha%CC%81dzal+pravdepodobne+opevneny%CC%81+vel%CC%8Cmoz%CC%8Cov+dvorec+s+viditel%CC%8Cny%CC%81mi+priekopami+a+valmi..jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EPohľad z hornej časti hradiska na dolnú časť. Vpravo sa nachádzal pravdepodobne opevnený veľmožov dvorec s viditeľnými priekopami a valmi\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgEXTd71a3zBLNAbrC11-8_cAPFMtwVNTJIvdgYjohlGlh5lP1bo4_GBlu-lJTeGaCzmVdEq7KZFmMW0x4JLwNqfL0i01zfS9VzzaiygcgzFCD4IJWfxhktx8OqXViS6hVW_lo6IRM4tu0\/s1600\/Stars%CC%8Cia+c%CC%8Cast%CC%8C,+s+najvys%CC%8Cs%CC%8Cie+poloz%CC%8Cenou+c%CC%8Cast%CC%8Cou+hradiska.+Tu+asi+sta%CC%81vala+hlavna%CC%81+obranna%CC%81+vez%CC%8Ca..jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" height=\"118\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgEXTd71a3zBLNAbrC11-8_cAPFMtwVNTJIvdgYjohlGlh5lP1bo4_GBlu-lJTeGaCzmVdEq7KZFmMW0x4JLwNqfL0i01zfS9VzzaiygcgzFCD4IJWfxhktx8OqXViS6hVW_lo6IRM4tu0\/s320\/Stars%CC%8Cia+c%CC%8Cast%CC%8C,+s+najvys%CC%8Cs%CC%8Cie+poloz%CC%8Cenou+c%CC%8Cast%CC%8Cou+hradiska.+Tu+asi+sta%CC%81vala+hlavna%CC%81+obranna%CC%81+vez%CC%8Ca..jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EStaršia časť, s najvyššie položenou časťou hradiska. Tu asi stávala hlavná obranná veža\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjJQQGUiKGvnH4Bceb9JlcAg_KIGWeH3PmQRbi6Xc_35sm-QTvtTi1q42rt7Y1pOqso3l47BPvan7x9zh5V8ojTQffCFofhCRbXLA5Pl466_QIxtWcD6AWaHKCvzpZd20a0dwAHQVchnKo\/s1600\/esta+z+hradiska+klesa%CC%81+odlesneny%CC%81m+svahom,+Vl%CC%8Cavo+je+navys%CC%8Cs%CC%8Cia+c%CC%8Cast%CC%8C+hradiska,+vpravo+niz%CC%8Cs%CC%8Cia..jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" height=\"84\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjJQQGUiKGvnH4Bceb9JlcAg_KIGWeH3PmQRbi6Xc_35sm-QTvtTi1q42rt7Y1pOqso3l47BPvan7x9zh5V8ojTQffCFofhCRbXLA5Pl466_QIxtWcD6AWaHKCvzpZd20a0dwAHQVchnKo\/s320\/esta+z+hradiska+klesa%CC%81+odlesneny%CC%81m+svahom,+Vl%CC%8Cavo+je+navys%CC%8Cs%CC%8Cia+c%CC%8Cast%CC%8C+hradiska,+vpravo+niz%CC%8Cs%CC%8Cia..jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003ECesta z hradiska klesá odlesneným svahom, Vľavo je navyššia časť hradiska, vpravo nižšia\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhWvwhl0UJEYAgmQyev2eQ18VBVzOcOwvofT1jYlOUzwxgxTg-6sshWXXy87Bt7HG41OtYnt7G-6g39hsYfkdG_bpL9Hw1ffqXJjIvEaIPq6r0IoNbuUIZO8OiFrwW9s05JoK6tqXEzewQ\/s1600\/JV+viditel%CC%8Cny%CC%81+val.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" height=\"180\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhWvwhl0UJEYAgmQyev2eQ18VBVzOcOwvofT1jYlOUzwxgxTg-6sshWXXy87Bt7HG41OtYnt7G-6g39hsYfkdG_bpL9Hw1ffqXJjIvEaIPq6r0IoNbuUIZO8OiFrwW9s05JoK6tqXEzewQ\/s320\/JV+viditel%CC%8Cny%CC%81+val.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EV pozadí dobre viditeľný val v JV časti\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\nO hradisku nebol žiadny písomný záznam. Niektorí výskumníci datujú stavbu hradu, asi dreveného, do 12. - 13. storočia. V predošlej dobe boli nájdené keramické nálezy - zo stredoveku. Hradisko bolo v stredoveku, v roku 1433 spolu s výšinou pri hrade Strečno osídlené Bratríkmi, vojskom. \u0026nbsp;Dr. Moravčík o tom uvádza, že sa využívalo opäť až začiatkom druhej polovice 15. stor. (okrem keramiky tiež nález mince Mateja Korvína z roku 1464) pravdepodobne vojskami bratríkov, ktorí tu operovali v rámci bojov o uhorský trón. Pod vplyvom neúspechov v bojoch pro­ti vojsku kráľa Mateja Korvína, najmä po porážke pri Veľkých Kostolanoch v roku 1467, sa stiahli do bezpečnejších aj lepšie chránených polôh severného a severozápad­ného Slovenska, kde sa pohybovali ešte aj okolo roku 1474\u003C\/div\u003E\n\u003C\/div\u003E\n\u003Cdiv\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv\u003E\nAutor: Heretik\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n(niektoré informácie pochádzaju zo stránky jupiter.elte.hu, iné z rôznych stránok alebo môjho pozorovania)\u003Cbr \/\u003E\nMORAVČÍK, J., 2002: Opevnenia severozápadného Slovenska. VZP XXI: 7-36\u003Cbr \/\u003E\nPETROVSKÝ-ŠICHMAN, A.: Slovanské osídlenie severného Slovenska. In: Vlastivedný Sbor. Považia. 6. Žilina—Banská Bystrica 1964, str. 73\u003C\/div\u003E\n\u003C\/div\u003E\n"},"link":[{"rel":"replies","type":"application/atom+xml","href":"http:\/\/www.hradiska.sk\/feeds\/8462600986895280963\/comments\/default","title":"Zverejniť komentáre"},{"rel":"replies","type":"text/html","href":"http:\/\/www.hradiska.sk\/2013\/05\/gbelany.html#comment-form","title":"0 komentárov"},{"rel":"edit","type":"application/atom+xml","href":"http:\/\/www.blogger.com\/feeds\/6818054921907446479\/posts\/default\/8462600986895280963"},{"rel":"self","type":"application/atom+xml","href":"http:\/\/www.blogger.com\/feeds\/6818054921907446479\/posts\/default\/8462600986895280963"},{"rel":"alternate","type":"text/html","href":"http:\/\/www.hradiska.sk\/2013\/05\/gbelany.html","title":"Gbeľany"}],"author":[{"name":{"$t":"Orgon"},"uri":{"$t":"http:\/\/www.blogger.com\/profile\/01396912608531297025"},"email":{"$t":"noreply@blogger.com"},"gd$image":{"rel":"http://schemas.google.com/g/2005#thumbnail","width":"32","height":"32","src":"\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjRf79q2mlg3o6