sY_W7_GnMHXspVw3fuuBpiYA7JlSOlY/s220/SH+Kruh+s+dlznom1.JPG"}}],"generator":{"version":"7.00","uri":"http://www.blogger.com","$t":"Blogger"},"openSearch$startIndex":{"$t":"1"},"openSearch$itemsPerPage":{"$t":"25"},"entry":[{"id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479.post-8027569205210478320"},"published":{"$t":"2010-05-23T17:09:00.005+02:00"},"updated":{"$t":"2018-02-06T07:16:49.291+01:00"},"category":[{"scheme":"http://www.blogger.com/atom/ns#","term":"Prečo to vlastne robím?"}],"title":{"type":"text","$t":"Prečo to vlastne robím?"},"content":{"type":"html","$t":"<div style=\"text-align: justify;\">\nTáto stránka bude venovaná predovšetkým starým slovanským hradiskám nachádzajúcim sa na území Slovenska, avšak nebudeme sa vyhýbať ani slovanským hradiskám  v ostatných štátoch, či hradiskám iných kultúr, najmä. Keltov, či Lužickej kultúry.<br />\n<div style=\"margin-bottom: 0in;\">\nNie som profesionálny historik, avšak o históriu Slovanov sa zaujímam už dlho popri iných povinnostiach, takže prosím o zhovievavosť.</div>\n<div style=\"margin-bottom: 0in;\">\nZistil som, že neexistuje stránka, ktorá by sa venovala starým hradiskám tak ako je to napr. v prípade hradov a zámkov. Informácie o jednotlivých hradiskách sa síce dajú nájsť, ale je to pomerne prácne a časovo náročné. Mojim zámerom je vytvoriť stránku, na ktorej bude čo najviac slovanských hradísk a ku každému hradisku by som rád zhromaždil pokiaľ možno komplexné informácie, ktoré sú v dnešnej dobe k dispozícii. Pôjde o dnes známu históriu hradiska, nálezy, nákresy, rekonštrukcie, fotografie atď. Najradšej by som sa dostal k absolútnemu základu - tzn. ku konkrétnym  prácam archeológov, ktorí hradiská skúmali v minulosti. To je ale ideálny stav, ktorý by som chcel dosiahnuť a je mi jasné, že k takémuto cieľu sa nepodarí dopracovať za 1-2 mesiace, ale je to dlhodobá záležitosť.<br />\n<br />\n<div class=\"separator\" style=\"clear: both; text-align: center;\">\n<a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEg-MpFlxJGkw1AQxedSCG1Di45Od0YywHzl4vj-ArqylUViQPKAvUVN5ndM5DPIA9TxF-q5CvwqsK4HxTyWfIJ0LtLcwt7YVtB8QlA9irc30iu7nzS4LWiuGn7iUqsP0NqCbHgcM7yxrIMj/s1600/14030839_171692423253423_141306167_n.png\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"><img border=\"0\" data-original-height=\"937\" data-original-width=\"960\" height=\"312\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEg-MpFlxJGkw1AQxedSCG1Di45Od0YywHzl4vj-ArqylUViQPKAvUVN5ndM5DPIA9TxF-q5CvwqsK4HxTyWfIJ0LtLcwt7YVtB8QlA9irc30iu7nzS4LWiuGn7iUqsP0NqCbHgcM7yxrIMj/s320/14030839_171692423253423_141306167_n.png\" width=\"320\" /></a></div>\n<br />\n</div>\n<div style=\"margin-bottom: 0in;\">\nPre začiatok sem hodím pár hradísk, ku ktorým som sa doposiaľ dopracoval a postupne sa budú pridávať ďalšie hradiská a podrobnejšie informácie k už existujúcim.</div>\n<div style=\"margin-bottom: 0in;\">\nMnohé články, ktoré si tu prečítate budú prevzaté od iných autorov, prípadne z iných stránok, kde sú informácie o hradiskách roztrúsené, pričom v takýchto prípadoch bude samozrejme vždy uvedený zdroj. V prípade, ak si niektorý autor nebude želať, aby jeho článok bol na tejto stránke uvedený, budem to samozrejme akceptovať a vymažem ho, ale dúfam, že takéto problémy nebudem musieť riešiť a že  ľudia pochopia, že sa tu jedná o neziskový blog, snažiaci sa s dobrým úmyslom informovať verejnosť  a podnietiť  k záujmu o našu spoločnú slávnu históriu.</div>\n<div style=\"margin-bottom: 0in;\">\nAk sa na túto stránku dostanú aj archeológovia a historici a budú chcieť niečo doplniť či poopraviť,  veľmi rád sa nechám poučiť.</div>\n<div style=\"margin-bottom: 0in;\">\n<br /></div>\n<div style=\"margin-bottom: 0in;\">\n<b>Prečo práve Slovanské Hradiská?</b></div>\n<div style=\"margin-bottom: 0in;\">\n<br /></div>\n<div style=\"margin-bottom: 0in;\">\nSlovanské hradiská sú nielen symbolom veľkého staviteľského umenia našich Slovanských predkov, ktorí pred viac ako 1000 rokmi dokázali budovať mohutné opevnenia, pred ktorými neraz kapitulovali aj najväčšie armády svojej doby, ale sú aj živým dôkazom ich nezávislosti, vyspelosti, hrdosti, bohatstva a politickej moci. Na hradiskách žili naši veľmoži so svojimi rodinami, vojenská družina, ale aj umní remeselníci - kováči, šperkári, ktorých výrobky môžeme vďaka archeológii obdivovať aj dnes, obchodníci, duchovenstvo a ostatní významní obyvatelia. Okrem budov obyčajného obyvateľstva, na hradiskách nachádzame reprezentatívne obydlia šľachty, prvé kresťanské kostoly, či pohanské svätyne.</div>\n<div style=\"margin-bottom: 0in;\">\n<br /></div>\n<div style=\"margin-bottom: 0in;\">\nCieľom stránky je tiež pútavou formou čitateľom priblížiť nesmierne zaujímavé obdobie našich národných dejín - raný stredovek, najmä v časoch Veľkej Moravy. Buďme hrdí na naše dejiny. Máme na to mnoho dôvodov.</div>\n<br />\n<div id=\"google_translate_element\" style=\"display: block;\">\n</div>\nOrgoň<br />\n<br />\nKONTAKT NA MŇA: &nbsp;<span style=\"font-size: large;\"><b> ORGON333@GMAIL.COM</b></span></div>\n<div style=\"text-align: justify;\">\n<br />\n<blockquote>\n</blockquote>\n<div class=\"separator\" style=\"clear: both; text-align: center;\">\n<a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhk-DBldYJWohZiXg4enh2wK0GqREg4QSPsriqgYsWyenHx3-8_bPSuZwIC7wA_js-5FNgVNaFYmjBRYdISnc6Cj-kNy0XF0IxpargogbkWZMyD_eOM79iiHq25EhBD8RUeMT1Ca57b3hI/s1600/Hlavic%CC%8Cka+web-stra%CC%81nky_2.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"><img border=\"0\" height=\"95\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhk-DBldYJWohZiXg4enh2wK0GqREg4QSPsriqgYsWyenHx3-8_bPSuZwIC7wA_js-5FNgVNaFYmjBRYdISnc6Cj-kNy0XF0IxpargogbkWZMyD_eOM79iiHq25EhBD8RUeMT1Ca57b3hI/s320/Hlavic%CC%8Cka+web-stra%CC%81nky_2.jpg\" width=\"320\" /></a></div>\n<br />\n<div class=\"separator\" style=\"clear: both; text-align: center;\">\n</div>\n<br />\n<br />\n<br />\n<div class=\"separator\" style=\"clear: both; text-align: center;\">\n<a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEiUoX6oxg0RhQ3fRLYCCYXuEAHXZRkq-jwi9-kd98KeuLptn9HC4HLu618TKBzNOegFlgFxgIghA4egSmSR2zmJnjdQ4YHnDKN9-0BRnOkQvpL7veaxdhaDvQeCyahA1L2_7y2LUR0mr_E/s1600/Slovansk%25C3%25A9+Hradisk%25C3%25A1+Banner.JPG\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"><img border=\"0\" height=\"240\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEiUoX6oxg0RhQ3fRLYCCYXuEAHXZRkq-jwi9-kd98KeuLptn9HC4HLu618TKBzNOegFlgFxgIghA4egSmSR2zmJnjdQ4YHnDKN9-0BRnOkQvpL7veaxdhaDvQeCyahA1L2_7y2LUR0mr_E/s320/Slovansk%25C3%25A9+Hradisk%25C3%25A1+Banner.JPG\" width=\"320\" /></a></div>\n</div>\n"},"link":[{"rel":"replies","type":"application/atom+xml","href":"http://www.hradiska.sk/feeds/8027569205210478320/comments/default","title":"Zverejniť komentáre"},{"rel":"replies","type":"text/html","href":"http://www.hradiska.sk/2010/05/uvod.html#comment-form","title":"11 komentárov"},{"rel":"edit","type":"application/atom+xml","href":"http://www.blogger.com/feeds/6818054921907446479/posts/default/8027569205210478320"},{"rel":"self","type":"application/atom+xml","href":"http://www.blogger.com/feeds/6818054921907446479/posts/default/8027569205210478320"},{"rel":"alternate","type":"text/html","href":"http://www.hradiska.sk/2010/05/uvod.html","title":"Prečo to vlastne robím?"}],"author":[{"name":{"$t":"Orgon"},"uri":{"$t":"http://www.blogger.com/profile/01396912608531297025"},"email":{"$t":"noreply@blogger.com"},"gd$image":{"rel":"http://schemas.google.com/g/2005#thumbnail","width":"32","height":"32","src":"//blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjRf79q2mlg3o6hsyWbYMCCgv1WaA6pM0mtkWB0QdJ76W64emXoS0lwpSlUw9K5iinuoAVrX4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY/s220/SH+Kruh+s+dlznom1.JPG"}}],"media$thumbnail":{"xmlns$media":"http://search.yahoo.com/mrss/","url":"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEg-MpFlxJGkw1AQxedSCG1Di45Od0YywHzl4vj