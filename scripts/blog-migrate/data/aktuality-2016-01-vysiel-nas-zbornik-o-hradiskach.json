4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY/s220/SH+Kruh+s+dlznom1.JPG"}}],"generator":{"version":"7.00","uri":"http://www.blogger.com","$t":"Blogger"},"openSearch$startIndex":{"$t":"1"},"openSearch$itemsPerPage":{"$t":"25"},"entry":[{"id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479.post-4275678494796461990"},"published":{"$t":"2016-01-19T20:43:00.000+01:00"},"updated":{"$t":"2018-01-16T12:44:26.264+01:00"},"title":{"type":"text","$t":"VYŠIEL NÁŠ ZBORNÍK O HRADISKÁCH !!!"},"content":{"type":"html","$t":"<div style=\"text-align: justify;\">\nNáš zborník \"Hradiská - Svedkovia dávnych čias\" je na svete. Vyšiel koncom decembra v náklade 500 kusov a už ich máme iba cca 250 kusov. Ako vidieť z priloženého obsahu, autormi článkov sú renomovaní archeológovia, pričom zborník má aj 2 recenzentov, čo zvyšuje jeho vedeckú úroveň.</div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div style=\"text-align: justify;\">\n&nbsp;Kto má o toto dielo záujem, neváhajte a objednajte si ho čím skôr na adrese: <u><i><b>zbornik.hradiska@gmail.com</b></i></u>. Jeho cena je <u><b>15 Eur</b></u>. Kúpou zborníka nás podporíte v ďalšej činnosti v budúcnosti.</div>\n<br />\n<div class=\"separator\" style=\"clear: both; text-align: center;\">\n<a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhndOZmSyfgdmB0zaf8m4kWbyBwWvMCxx8buYlviSTnk8E15gH5QHAcy-9KcSanlUDsb5UZ56HGvDfC3mOxgb8pYXfpFrvqpXpvRieD_k8vglfDYSeRBTMh030htPsgJCOkSMJIDJTD_PM/s1600/12552653_10208229828964575_3607983513671215064_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"><img border=\"0\" height=\"320\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEhndOZmSyfgdmB0zaf8m4kWbyBwWvMCxx8buYlviSTnk8E15gH5QHAcy-9KcSanlUDsb5UZ56HGvDfC3mOxgb8pYXfpFrvqpXpvRieD_k8vglfDYSeRBTMh030htPsgJCOkSMJIDJTD_PM/s320/12552653_10208229828964575_3607983513671215064_n.jpg\" width=\"320\" /></a></div>\n<div style=\"text-align: center;\">\n<a href=\"https://www.academia.e