eusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjRf79q2mlg3o6hsyWbYMCCgv1WaA6pM0mtkWB0QdJ76W64emXoS0lwpSlUw9K5iinuoAVrX4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY\/s220\/SH+Kruh+s+dlznom1.JPG"}}],"generator":{"version":"7.00","uri":"http://www.blogger.com","$t":"Blogger"},"openSearch$totalResults":{"$t":"1"},"openSearch$startIndex":{"$t":"1"},"openSearch$itemsPerPage":{"$t":"5"},"entry":[{"id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479.post-6664958246006606558"},"published":{"$t":"2020-03-23T00:43:00.000+01:00"},"updated":{"$t":"2020-03-29T13:18:35.147+02:00"},"category":[{"scheme":"http://www.blogger.com/atom/ns#","term":"Železník (Dolné Orešany)"}],"title":{"type":"text","$t":"Železník (Dolné Orešany)"},"content":{"type":"html","$t":"\u003Cbr \/\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003EHradisko Železník sa nachádza v\u0026nbsp;katastri\nobce Dolné Orešany. Najlepší prístup k\u0026nbsp;nemu však vedie cez Horné Orešany,\nktoré je potrebné prejsť a\u0026nbsp;následne za obcou zabočiť smerom na Lošonec a\u0026nbsp;následne\nna Majdán, kde v\u0026nbsp;lokalite pri Olšovskom mlyne na malom parkovisku necháte\nzaparkované auto a\u0026nbsp;ďalej pokračujete po zelenej turistickej značke popri\nHusom stoku. Približne po 25 minútach ľahkej turistiky po asfaltke, kedy\nprejdete okolo spomenutého Husieho Stoku, okolo hrádku Vápenná a\u0026nbsp;pozdĺž zaniknutej\nželezničky, sa pred Vami vľavo objaví výrazný kužeľovitý kopec s\u0026nbsp;pomerne strmými\nsvahmi, ktorý nesie názov Železník. \u003Co:p\u003E\u003C\/o:p\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cbr \/\u003E\n\u003Ciframe frameborder=\"0\" height=\"280\" src=\"https:\/\/sk.frame.mapy.cz\/s\/debuboduvu\" style=\"border: none;\" width=\"400\"\u003E\u003C\/iframe\u003E\u003Cbr \/\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Co:p\u003E\u003Cbr \/\u003E\u003C\/o:p\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiTQKI66QfE6jkDK-p2C69Klcw0Ij78tOmVx_cJSDzAZVr-VnmlitObWEyNd36l_XTN9IhaRinku4WasgKWEwXcs8j2kv0Zr0xHVa35ihnS5yPqr9oCfsSGlUbBUa1wgTSMfh5t9X3WYo9U\/s1600\/LIDAR+original.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" data-original-height=\"745\" data-original-width=\"797\" height=\"299\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiTQKI66QfE6jkDK-p2C69Klcw0Ij78tOmVx_cJSDzAZVr-VnmlitObWEyNd36l_XTN9IhaRinku4WasgKWEwXcs8j2kv0Zr0xHVa35ihnS5yPqr9oCfsSGlUbBUa1wgTSMfh5t9X3WYo9U\/s320\/LIDAR+original.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Co:p\u003E\u003Cbr \/\u003E\u003C\/o:p\u003E\u003C\/span\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Co:p\u003E\u003Cbr \/\u003E\u003C\/o:p\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003EVedie k\u0026nbsp;nemu dodnes viditeľná\nstará cesta, ktorá začína kolmo na dnešnú asfaltku a\u0026nbsp;tiahne sa zo severu\nna juh, pričom po pár desiatkach metrov začne odbočovať doprava a\u0026nbsp;pomaly sa\ntiahne šikmo cez vrstevnice okolo kopca až smerom na vrchol. V\u0026nbsp;juhozápadnej\nčasti asi v\u0026nbsp;hornej polovici svahu cesta prechádza cez \u003Cspan style=\"mso-spacerun: yes;\"\u003E\u0026nbsp;\u003C\/span\u003Ezaujímavú plošinku, na ktorej boli objavené\nviaceré nálezy z\u0026nbsp;obdobia stredoveku a\u0026nbsp;na ktorej možno stála vstupná\nbrána na samotné hradisko. Tento môj predpoklad však zatiaľ nie je exaktne\ndoložený výskumom. Nie ďaleko od uvedeného miesta potom cesta plynule prechádza\ndo výraznej sídliskovej a\u0026nbsp;zrejme pôvodne na okrajoch drevenou palisádou opevnenej\nterasy, ktorá sa tiahne okolo celého kopca. Vrchol Železníka tvorí pomerne\nrovná plocha, na ktorej zrejme stáli pôvodne drevené budovy. Stopy po\nstredovekej kamenej architektúre sa zatiaľ nenašli. \u003Co:p\u003E\u003C\/o:p\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Co:p\u003E\u0026nbsp;\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEipnOEheylaW8FGpCCUkiTJVtRUYwukGPY7KXDHQwr5CPEPHKbkvlrs4Tm61IKPRhhgmwHMs25k-wcePNOODJdJenMya5crG0W3Q7ejqk-vK-VqsLZ1bR37qXWNRbq98Z9Pr7a7jPx6k_AF\/s1600\/DJI_0279.JPG\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"1200\" data-original-width=\"1600\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEipnOEheylaW8FGpCCUkiTJVtRUYwukGPY7KXDHQwr5CPEPHKbkvlrs4Tm61IKPRhhgmwHMs25k-wcePNOODJdJenMya5crG0W3Q7ejqk-vK-VqsLZ1bR37qXWNRbq98Z9Pr7a7jPx6k_AF\/s320\/DJI_0279.JPG\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003ENa leteckej snímke výborne viditeľná sídlisková terasa, \u003Cbr \/\u003E\nna ktorej okraji mohla byť drevená palisáda, chrániaca hradisko\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003C\/o:p\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Cbr \/\u003E\u003C\/span\u003E\n\u003Cbr \/\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEj3COQFy9SjcWO39kpHuoskW5qrO-DonRFsfswr6qh6PtnYXYjTkdkVcMZ7r-O_iAaBODvutzVBYTy9uK_GaiC8h4xiORIzv-kNZ3VlTFqe56rbXShHMhGWJVEgZeb6KeWEg7YUsncNZ_lN\/s1600\/90670771_611461122737796_5343503185300422656_n.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"720\" data-original-width=\"960\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEj3COQFy9SjcWO39kpHuoskW5qrO-DonRFsfswr6qh6PtnYXYjTkdkVcMZ7r-O_iAaBODvutzVBYTy9uK_GaiC8h4xiORIzv-kNZ3VlTFqe56rbXShHMhGWJVEgZeb6KeWEg7YUsncNZ_lN\/s320\/90670771_611461122737796_5343503185300422656_n.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EPohľad na hradisko od severu\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEi7CFhsUkF8GSk87XQdLr_0qhUTGEwtPfyhClwoOcE6v1O48xvtI1IDQjl37XY6jyWyNYHJn7vhE71v_wJ54h8vdrJtKd8l0kVz7cCLGjKwi1DTbcxlkHcPf1AGZxGARdPAzk64Ij-QsR0k\/s1600\/90504575_611461066071135_9135898778694320128_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" data-original-height=\"720\" data-original-width=\"960\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEi7CFhsUkF8GSk87XQdLr_0qhUTGEwtPfyhClwoOcE6v1O48xvtI1IDQjl37XY6jyWyNYHJn7vhE71v_wJ54h8vdrJtKd8l0kVz7cCLGjKwi1DTbcxlkHcPf1AGZxGARdPAzk64Ij-QsR0k\/s320\/90504575_611461066071135_9135898778694320128_n.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Cbr \/\u003E\u003C\/span\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Cbr \/\u003E\u003C\/span\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003EHradisko sa nachádza v\u0026nbsp;doline\nParnej, cez ktorú zrejme v\u0026nbsp;minulosti viedla jedna z\u0026nbsp;ciest smerom na\nzápad, konkrétne na Sološnicu, resp. Rohožník, z\u0026nbsp;čoho celkom nepochybne\nvyplýva predovšetkým jeho strategická strážna funkcia. Podobnú funkciu zrejme\nplnilo aj niekoľko stoviek metrov vzdialené opevnenie Vápenice. \u003Co:p\u003E\u003C\/o:p\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Co:p\u003E\u0026nbsp;\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhUCdQgLiu1PYD5IlM8Qa2aTBzoaDsD1He2IBOPrvcrNYmZh_OHtAGsQgGYrPzIzGK_rBK2ZJaeTfuwu23AbF1tGLUJrY-AJ5GREcM9uv3lZPpCJYqj3zkyLlAgMspAUzr07UeTwkT6LcbS\/s1600\/kruzky.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"353\" data-original-width=\"418\" height=\"270\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhUCdQgLiu1PYD5IlM8Qa2aTBzoaDsD1He2IBOPrvcrNYmZh_OHtAGsQgGYrPzIzGK_rBK2ZJaeTfuwu23AbF1tGLUJrY-AJ5GREcM9uv3lZPpCJYqj3zkyLlAgMspAUzr07UeTwkT6LcbS\/s320\/kruzky.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EKrúžková zbroj zo Železníka\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003C\/o:p\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003ENa uvedenom hradisku vykonával\nvýskum v\u0026nbsp;90. rokoch Zdenek Farkaš a v\u0026nbsp;rokoch 2018 až 2020 tu\nrealizovalo archeologický výskum Slovenské národné múzeum pod vedením Pavla\nJelínka, pričom naše OZ Hradiská sa výskumu zúčastnilo v\u0026nbsp;rámci dobrovoľníckej\nčinnosti. Počas výskumu sme objavili množstvo veľmi zaujímavých nálezov najmä z\u0026nbsp;obdobia\nstredoveku. \u003Cspan style=\"mso-spacerun: yes;\"\u003E\u0026nbsp;\u003C\/span\u003E\u003Co:p\u003E\u003C\/o:p\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt;\"\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Co:p\u003E\u0026nbsp;\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEj1_QigtBKU8_n9iKorYjy0gaCsiXMccw5gGYyvj5x2XJowTFsC7pvU9-nR-6nT1g5Mo-DXL2AS9ZibQYl9eR6o6pYJYx21nqLoHPfWusJwYhjrWAIvT93WFFhs6mRYlWZsozMGtz7oAxQN\/s1600\/38802607_296469060903672_5504275411896369152_n.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"720\" data-original-width=\"960\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEj1_QigtBKU8_n9iKorYjy0gaCsiXMccw5gGYyvj5x2XJowTFsC7pvU9-nR-6nT1g5Mo-DXL2AS9ZibQYl9eR6o6pYJYx21nqLoHPfWusJwYhjrWAIvT93WFFhs6mRYlWZsozMGtz7oAxQN\/s320\/38802607_296469060903672_5504275411896369152_n.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EFalošné mince, ústrižky a 2 fragmenty strieborných mincí. \u003Cbr \/\u003E\nPod nimi typický stredoveký okraj keramickej nádoby\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003C\/o:p\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cspan style=\"mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003ENa Železníku a\u0026nbsp;v\u0026nbsp;jeho\nokolí sa usadili už ľudia v\u0026nbsp;období ludanickej skupiny (starý eneolit), a neskôr\nho využili v\u0026nbsp;strednej až mladšej dobe bronzovej, z\u0026nbsp;ktorej pochádza\nniekoľko kovových nálezov, a\u0026nbsp;dobe halštatskej. Najvýraznejšie však bol\nosídlený v\u0026nbsp;období stredoveku, a to cca od 11. do 15. storočia, pričom je\ndôvodné predpokladať, že v\u0026nbsp;13. storočí bol cieľom útoku niektorej z\u0026nbsp;vtedajších\narmád, najpravdepodobnejšie armády Přemysla Otakara II., ktorej pripisujeme\nzničenie viacerých hrádkov v\u0026nbsp;oblasti Malých Karpát, napr. hrádku Altenburg\nv\u0026nbsp;Pezinku. Hradisko je zaujímavé z\u0026nbsp;celoslovenského hľadiska tým, že\nna jeho vrchole a\u0026nbsp;svahoch sa našlo okolo 2 tisíc falošných mincí\nvychádzajúcich zo vzoru viedenských fenigov v\u0026nbsp;rôznom štádiu výroby.\nZhotovovali ich z\u0026nbsp;bronzových nádob postupne strihaných na dlhé pásiky,\nz\u0026nbsp;nich vystrihovali štvorcové „strižky“, na ne vyrážali nevýrazný štvorec\na\u0026nbsp;napokon postriebrovali. Viac ako 20\u003Cspan style=\"mso-spacerun: yes;\"\u003E\u0026nbsp;\n\u003C\/span\u003Etýchto falošných mincí sme objavili aj počas nášho výskumu.\nFalšovateľská dielňa sa zrejme nachádzala v\u003Cspan style=\"color: #231f20; letter-spacing: -0.7pt;\"\u003E zdokumentovanej \u003C\/span\u003E\u003Cspan style=\"color: #231f20;\"\u003Ezrubovej\nstavbe. Páchateľom bol teda zrejme miestny hradný pán. Spolu sa tu počas\nvýskumu v\u0026nbsp;90. rokoch zistilo asi tisíc predmetov, na základe ktorých možno\nrekonštru\u003Cspan style=\"letter-spacing: -.7pt;\"\u003Eovať celý proces falšovania peňazí\n– od výroby kotúčikov na mince až \u003C\/span\u003Epo ich razbu. \u003Co:p\u003E\u003C\/o:p\u003E\u003C\/span\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cspan style=\"color: #231f20; mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Co:p\u003E\u0026nbsp;\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgrMQ_YWbIxEjv9m1wf8jtj9Myk7EYvBgE0q8esMnvvChkrmSPdTEK79KJNJhkbgPXQe8oh2pcvrFXvRF_Vw8QrLOGjUrSSabO7DQmA3qP0Vaqz5DR7FCTYFlIcPJ-W0TewlPeVUjTcuFO5\/s1600\/47573119_348427659041145_2049866600504360960_o.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"640\" data-original-width=\"960\" height=\"213\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgrMQ_YWbIxEjv9m1wf8jtj9Myk7EYvBgE0q8esMnvvChkrmSPdTEK79KJNJhkbgPXQe8oh2pcvrFXvRF_Vw8QrLOGjUrSSabO7DQmA3qP0Vaqz5DR7FCTYFlIcPJ-W0TewlPeVUjTcuFO5\/s320\/47573119_348427659041145_2049866600504360960_o.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EKľúč, 2 šípy a 2 falošné mince\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003C\/o:p\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt; text-align: justify;\"\u003E\n\u003Cspan style=\"color: #231f20; mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003ENálezy pomerne\npočetných militárií svedčia o\u0026nbsp;možnej vojenskej likvidácii hradiska koncom\n13. storočia. Aj počas nášho výskumu sme najmä na juhozápadnom svahu hradiska v\u0026nbsp;blízkosti\npredpokladanej brány našli spolu 6 železných šípov, typických pre obdobie\nvrcholného stredoveku a\u0026nbsp;spolu 3 ostrohy, pričom dve je možné predbežne datovať\ndo obdobia 12. – 13. storočia a\u0026nbsp;jednu do 15. storočia. Do tohto obdobia tiež môžeme radiť aj záštitu z tesáka. Okrem toho sa na\nhradisku v\u0026nbsp;90. rokoch našla časť krúžkového brnenia, čo je pomerne vzácny\nnález z\u0026nbsp;obdobia stredoveku. Počas nášho výskumu boli na hradisku objavené tiež\nveľmi pekne zachované dva gotické kľúče, pracky, nože, dva fragmenty zo\nstredovekých mincí, gombík, kvetinovité ozdoby a\u0026nbsp;iné nálezy.\u0026nbsp;\u003C\/span\u003E\u0026nbsp;\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt;\"\u003E\n\u003Co:p\u003E\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjlbsiA2JPSId1FUBx_-1gxVyPNmwermTKOiTxYio7zzEE5MibzRZYO3iFTjbMTMgDWL1BGnJzbwcFajY3X-gZDO_sM6zB6yFlTejr_ixw4HOjp21CMiGizK2sIaNrL4KtyO3JxVlPJcLp3\/s1600\/38806644_296468944237017_6539211763995377664_n.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"960\" data-original-width=\"720\" height=\"320\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjlbsiA2JPSId1FUBx_-1gxVyPNmwermTKOiTxYio7zzEE5MibzRZYO3iFTjbMTMgDWL1BGnJzbwcFajY3X-gZDO_sM6zB6yFlTejr_ixw4HOjp21CMiGizK2sIaNrL4KtyO3JxVlPJcLp3\/s320\/38806644_296468944237017_6539211763995377664_n.jpg\" width=\"240\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EStredoveká keramika z akropoly hradiska\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003C\/o:p\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjCO6Di1C83BsA4mCwzL74g2BDOqWoJNYEuU7q4lRjE_Z5rQbwTmp_F9QOaedvCO4veD7AT0fLkdsjtDBpRwbZzRwtM891_gRbYBX9fmGCg2NX5CyXay0gFxRTCX8OUoflhlExxnQZmgDgb\/s1600\/74496911_515250269025549_3266374988554305536_n.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"720\" data-original-width=\"960\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjCO6Di1C83BsA4mCwzL74g2BDOqWoJNYEuU7q4lRjE_Z5rQbwTmp_F9QOaedvCO4veD7AT0fLkdsjtDBpRwbZzRwtM891_gRbYBX9fmGCg2NX5CyXay0gFxRTCX8OUoflhlExxnQZmgDgb\/s320\/74496911_515250269025549_3266374988554305536_n.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EStarší typ ostrohy\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEg4w83FoqWL6SAjk9yi0x_mRGhV_-y3_k39tXrhnm5QRYzQdXCTtOVc9gIy870yFKdo8JDuj4GH_vRuyHl-Cf0QSGliS9EC8-ttBFwqlx4W7FyMjQj2BiftZw9C6D3TJ38ZG66ps7YJZ-yF\/s1600\/IMG_4017.JPG\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"1067\" data-original-width=\"1600\" height=\"213\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEg4w83FoqWL6SAjk9yi0x_mRGhV_-y3_k39tXrhnm5QRYzQdXCTtOVc9gIy870yFKdo8JDuj4GH_vRuyHl-Cf0QSGliS9EC8-ttBFwqlx4W7FyMjQj2BiftZw9C6D3TJ38ZG66ps7YJZ-yF\/s320\/IMG_4017.JPG\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EMladší typ ostrohy (14.\/15. storočie)\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt;\"\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"-webkit-text-stroke-width: 0px; color: black; font-family: \u0026quot;Times New Roman\u0026quot;; font-size: medium; font-style: normal; font-variant-caps: normal; font-variant-ligatures: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: start; text-decoration-color: initial; text-decoration-style: initial; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px;\"\u003E\n\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"-webkit-text-stroke-width: 0px; color: black; font-family: \u0026quot;Times New Roman\u0026quot;; font-size: medium; font-style: normal; font-variant-caps: normal; font-variant-ligatures: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: justify; text-decoration-color: initial; text-decoration-style: initial; text-indent: 0px; text-transform: none; white-space: normal; widows: 2; word-spacing: 0px;\"\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEh5_u3k2MtziJYfvMRK8Hx1QwU-54lqMUvOvh8LQvII4koq2zVfrhfTdKqKXQwlP2ctMrrqiwHS-a2qvpACQ-cUmdJlxMzj2mAn0yV166ZNblAkvDjPrzr4kV2H8Xuya5Q7hBR6aZsxXxTX\/s1600\/IMG_4022.JPG\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"1067\" data-original-width=\"1600\" height=\"213\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEh5_u3k2MtziJYfvMRK8Hx1QwU-54lqMUvOvh8LQvII4koq2zVfrhfTdKqKXQwlP2ctMrrqiwHS-a2qvpACQ-cUmdJlxMzj2mAn0yV166ZNblAkvDjPrzr4kV2H8Xuya5Q7hBR6aZsxXxTX\/s320\/IMG_4022.JPG\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003ESúbor niektorých nálezov - gombík, záštita z tesáka, nôž, šípy, ozdoby, \u003Cbr \/\u003E\nfalošné mince, a zrejme krúžok z brnenia\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cdiv style=\"margin: 0px;\"\u003E\n\u003Cspan style=\"color: #231f20; mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Cbr \/\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv style=\"margin: 0px;\"\u003E\n\u003Cspan style=\"color: #231f20; mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003E\u003Cbr \/\u003E\u003C\/span\u003E\u003C\/div\u003E\n\u003Cdiv style=\"margin: 0px;\"\u003E\n\u003Cspan style=\"color: #231f20; mso-bidi-font-family: \u0026quot;Times New Roman\u0026quot;;\"\u003EZaujímavosťou je tiež predsunutý val s\u0026nbsp;hlbokou priekopou, nachádzajúci sa na južnom úpätí hradiska. Zdenek Farkaš uvádza, že val zrejme nebol dokončený, pričom predpokladá jeho vznik v\u0026nbsp;dobe bronzovej. Nám sa v\u0026nbsp;jeho blízkom okolí nepodarilo objaviť žiadne nálezy, ktoré by ho mohli bližšie datovať.\u003C\/span\u003E\u003Co:p\u003E\u003C\/o:p\u003E\u003C\/div\u003E\n\u003C\/div\u003E\n\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt;\"\u003E\n\u003Cbr \/\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgKNXUA8B9BShQo7uL7AuCSvF0vL8C7ICTrEYzj_xx-XXyBiXFm0tRzcIBqaorcv8rOCfgnV7P75YFsOJIeohYYPB2V0vtc5Ac-igjdXzjVJAnCBbIJlmGEn1PQazz3jDeXVzwi-IlsVon2\/s1600\/val.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"720\" data-original-width=\"960\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgKNXUA8B9BShQo7uL7AuCSvF0vL8C7ICTrEYzj_xx-XXyBiXFm0tRzcIBqaorcv8rOCfgnV7P75YFsOJIeohYYPB2V0vtc5Ac-igjdXzjVJAnCBbIJlmGEn1PQazz3jDeXVzwi-IlsVon2\/s320\/val.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EPredsunutý val s priekopou\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cbr \/\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv class=\"MsoNormal\" style=\"mso-line-height-alt: 5.0pt;\"\u003E\nToto hradisko má veľké\ngenius loci a\u0026nbsp;každému odporúčam jeho návštevu. Zatiaľ na ňom nie je\numiestnená žiadna informačná tabuľa, avšak predpokladám, že naše OZ\u003Cspan style=\"mso-spacerun: yes;\"\u003E\u0026nbsp; \u003C\/span\u003EHradiská v\u0026nbsp;budúcnosti jednu vytvorí...\u003Co:p\u003E\u003C\/o:p\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgaKCgVN55W-6pg9f3p9b4pydFmszzdnYwbVA0Dngk_qdWTAfuLJqTIuSswNWNeWHvdSoKO8oaqBVe1uwVIx1ktSZugajgVk1WO3IRAgz84jT7WWNfuFtoSnbSZ7-85Cya2kw1xhgyocvPn\/s1600\/IMG_4169n.JPG\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" data-original-height=\"1067\" data-original-width=\"1600\" height=\"213\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgaKCgVN55W-6pg9f3p9b4pydFmszzdnYwbVA0Dngk_qdWTAfuLJqTIuSswNWNeWHvdSoKO8oaqBVe1uwVIx1ktSZugajgVk1WO3IRAgz84jT7WWNfuFtoSnbSZ7-85Cya2kw1xhgyocvPn\/s320\/IMG_4169n.JPG\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgeOc7Er0Di8YdMguoNB8jFt1BclFD5iCCYzfweWwaxq4c3yXcOP2jL2D9OgNNxO9gazYPSqgMJbeIJEONEr8_he6CPgFjoPNxHphC4Y-JFTUZG0mU03RDEwCY0Y2yBQPv8Qr1Zr4C4KixQ\/s1600\/90597103_611461172737791_8527783498944086016_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" data-o