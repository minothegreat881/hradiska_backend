    "entry": [
      {
        "id": {
          "$t": "tag:blogger.com,1999:blog-6818054921907446479.post-556692350263317296"
        },
        "published": {
          "$t": "2011-09-28T17:45:00.008+02:00"
        },
        "updated": {
          "$t": "2024-11-03T11:02:08.342+01:00"
        },
        "category": [
          {
