mtkWB0QdJ76W64emXoS0lwpSlUw9K5iinuoAVrX4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY\/s220\/SH+Kruh+s+dlznom1.JPG"}}],"generator":{"version":"7.00","uri":"http://www.blogger.com","$t":"Blogger"},"openSearch$totalResults":{"$t":"1"},"openSearch$startIndex":{"$t":"1"},"openSearch$itemsPerPage":{"$t":"5"},"entry":[{"id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479.post-5507753766734512788"},"published":{"$t":"2011-07-25T14:42:00.001+02:00"},"updated":{"$t":"2017-08-30T13:50:46.830+02:00"},"category":[{"scheme":"http://www.blogger.com/atom/ns#","term":"Dreveník"}],"title":{"type":"text","$t":"Dreveník - Slovanské hradisko v tieni Spišského hradu"},"content":{"type":"html","$t":"\u003Ch1 style=\"text-align: justify;\"\u003E\n\u003C\/h1\u003E\n\u003Cdiv\u003E\n\u003C\/div\u003E\n\u003Cdiv class=\"articlec col\" id=\"article-box\" style=\"text-align: justify;\"\u003E\n\u003Cdiv id=\"itext_content\"\u003E\n\u003Cb style=\"font-weight: normal;\"\u003EPrinášame ďalšie zaujímavé Slovanské hradisko z Východného Slovenska.\u003C\/b\u003E\u003Cbr \/\u003E\n\u003Cb style=\"font-weight: normal;\"\u003E\u003Cbr \/\u003E\u003C\/b\u003E\n\u003Cspan\u003E\u003Ciframe allowfullscreen=\"\" frameborder=\"0\" height=\"315\" src=\"https:\/\/www.youtube.com\/embed\/7cJT2cMQUls\" width=\"560\"\u003E\u003C\/iframe\u003E\u003C\/span\u003E\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cb style=\"font-weight: normal;\"\u003EV\u0026nbsp;Hornádskej kotline, juhovýchodne od mesta Spišské  Podhradie, sa nachádza najväčšia travertínová kopa na Slovensku,  unikátny prírodný útvar so skalným mestom, s minimálne stredoeurópskym  významom. Vrcholová plošina predstavovala výnimočnú polohu, využívanú  takmer vo všetkých historických obdobiach na obranné účely.  Najvýraznejšie stavebné aktivity pochádzajú z\u0026nbsp;9. - 11. storočia, keď tam  stálo slovanské hradisko, podľa ktorého drevených fortifikačných  a\u0026nbsp;obytných konštrukcií bolo územie pomenované Dreveník.\u0026nbsp;\u0026nbsp;\u0026nbsp;\u0026nbsp;\u003C\/b\u003E\u003Cbr \/\u003E\n\u003Cb style=\"font-weight: normal;\"\u003E\u003Cbr \/\u003E\n\u003C\/b\u003E\u003Cbr \/\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhOetTkq8kjZ1m7JYrCWqvKtxcc5QNFuvYP34HPfOsnDHFtBKw91UT1XTyhDPzjYl2PEFoEBBeqbESlTaFr1thYckCuiyA64WhyphenhyphenTjn4oeFjlhuepdafjPQk0Ep-wJ25S92KpQG08_XlTtE\/s1600\/drevenik-r778_res.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhOetTkq8kjZ1m7JYrCWqvKtxcc5QNFuvYP34HPfOsnDHFtBKw91UT1XTyhDPzjYl2PEFoEBBeqbESlTaFr1thYckCuiyA64WhyphenhyphenTjn4oeFjlhuepdafjPQk0Ep-wJ25S92KpQG08_XlTtE\/s1600\/drevenik-r778_res.jpg\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003ENa hornej fotografii je zvýraznený priebeh valu opevnenia\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiQwaQNq9K8ERZdja97wNv3dQ5_rNzlmyG2yt5-pxr4HnSNbkUGiXnGZ-qkZXWzobUOY4vVyRJB67DYEt0R9wt9qlzR8PXmvfg9h8Bj4QluhM2o8_iO7YUGMoVlZu8WFfZR6NySZqhH-C8\/s1600\/pla%CC%81nik.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" height=\"320\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiQwaQNq9K8ERZdja97wNv3dQ5_rNzlmyG2yt5-pxr4HnSNbkUGiXnGZ-qkZXWzobUOY4vVyRJB67DYEt0R9wt9qlzR8PXmvfg9h8Bj4QluhM2o8_iO7YUGMoVlZu8WFfZR6NySZqhH-C8\/s320\/pla%CC%81nik.jpg\" width=\"212\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EPlánik hradiska\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEg0vnWstH3LHlfdKRFCz6bkHsr_toDGIDXpLZCFapqs1LTz0hyphenhyphenRXUv5Bp0SnCcOt4NYLfqmBdy1VL1iVCkUN024y1EFqOO2ifehNZ7w85KXmSff_gGSVd0OoBL8Yzk4bWYEEDyac-DHtQk\/s1600\/21056011_164305050786741_135217831982475803_o.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" data-original-height=\"810\" data-original-width=\"1440\" height=\"180\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEg0vnWstH3LHlfdKRFCz6bkHsr_toDGIDXpLZCFapqs1LTz0hyphenhyphenRXUv5Bp0SnCcOt4NYLfqmBdy1VL1iVCkUN024y1EFqOO2ifehNZ7w85KXmSff_gGSVd0OoBL8Yzk4bWYEEDyac-DHtQk\/s320\/21056011_164305050786741_135217831982475803_o.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjy4SvWtZBz_3u7LGHGXQyxuHlvDv5SyWPWYWedIF9OWXEEW3nk_kuXftVy6OvidioV_CKbwyYY08gejFyUj1KZ4zNsig3qmCQ2zRR1wnKZWTofbdC45Qox4tL4I64A3ClAUgbjWshFb6Y\/s1600\/21122354_164296174120962_3991911897061214372_o.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" data-original-height=\"1080\" data-original-width=\"1440\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjy4SvWtZBz_3u7LGHGXQyxuHlvDv5SyWPWYWedIF9OWXEEW3nk_kuXftVy6OvidioV_CKbwyYY08gejFyUj1KZ4zNsig3qmCQ2zRR1wnKZWTofbdC45Qox4tL4I64A3ClAUgbjWshFb6Y\/s320\/21122354_164296174120962_3991911897061214372_o.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjRWXj9BWng9hw3IwHr_6KckhtzWqeyIiWlqKaL1Wz-mN-fOlXQ-Q3AdzuR9o7fR_lfKsVcdqqPIoxZiO-0CTcf2U3oANQYQgB1gYzp1V-CVuqxj_IhMdruYJ_EyXN7pRU4SxefA43CWes\/s1600\/21122681_164438917440021_8955340332849275371_o.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" data-original-height=\"810\" data-original-width=\"1440\" height=\"180\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjRWXj9BWng9hw3IwHr_6KckhtzWqeyIiWlqKaL1Wz-mN-fOlXQ-Q3AdzuR9o7fR_lfKsVcdqqPIoxZiO-0CTcf2U3oANQYQgB1gYzp1V-CVuqxj_IhMdruYJ_EyXN7pRU4SxefA43CWes\/s320\/21122681_164438917440021_8955340332849275371_o.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cbr \/\u003E\nOd  konca treťohôr sa tektonickými poruchami na vápence prekryté zlepencami  či ílovcami dostáva voda obohatená o hydrouhličitan vápenatý. Jeho  sedimentáciou sa z teplých minerálnych prameňov za spolupôsobenia tlaku,  teploty a klímy ukladali travertínové vrstvy v charakteristických  kopách. Oproti ostatným kopám (Pažica či Sivá Brada) bol Dreveník viac  mechanicky rozrušovaný, čím vznikli skalné veže, jaskyne, pukliny a pod.  Okraje Dreveníka tvoria tak strmé, väčšinou kolmé, až 60 m vysoké  steny. Vrchol kopy bol pritom zarovnávaný, čoho výsledkom je priam  dokonalý priestor na úkryt, resp. výstavbu obranných zariadení. Z\u0026nbsp;tohto  nedobytného miesta so značným prevýšením oproti okoliu bol aj výborný  rozhľad na celú kotlinu. Ak by aj nepriateľ dobyl rozsiahlu vrcholovú  plošinu s\u0026nbsp;dokonalým potenciálom na výstavbu obytných štruktúr,  existovala aj záložná možnosť úkrytu v\u0026nbsp;jaskynných systémoch. \u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003C\/div\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhwLwcKjlgwXIguBIO1oiK-CPHMm0ZyWmZ9zQBjU4hCuDIkhqLZJgF24BIfKPPCe-KLFX4Kp2JTWQC2ZgvmH6w0WAHG3bouwBkxIDDxVVx-egz8Ouoj_2Bet7h7UKmFli0lSgi6tf4iQRE\/s1600\/285688_368678253215873_88858062_n.jpeg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhwLwcKjlgwXIguBIO1oiK-CPHMm0ZyWmZ9zQBjU4hCuDIkhqLZJgF24BIfKPPCe-KLFX4Kp2JTWQC2ZgvmH6w0WAHG3bouwBkxIDDxVVx-egz8Ouoj_2Bet7h7UKmFli0lSgi6tf4iQRE\/s320\/285688_368678253215873_88858062_n.jpeg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEikJh4Fdq_xSetdOKjj9O0qmRPzD0x5Cbak_K9j5tQl2v1V_1_IqhHBCxGGCfTQ9w89jYycDN_CtwUOjQ04JPbUCm88X7qDhwVxkktn2P5K91WJtWdQbdgpI-SkXL4A8WLCJVupq6S1Bxo\/s1600\/292718_368678296549202_1549884407_n.jpeg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEikJh4Fdq_xSetdOKjj9O0qmRPzD0x5Cbak_K9j5tQl2v1V_1_IqhHBCxGGCfTQ9w89jYycDN_CtwUOjQ04JPbUCm88X7qDhwVxkktn2P5K91WJtWdQbdgpI-SkXL4A8WLCJVupq6S1Bxo\/s320\/292718_368678296549202_1549884407_n.jpeg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EVal\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjPyzFSiRPskPW1Fm_AEn7wtZfmEIt2_DEYf4SOjb5iKRTvMKKwPw43h4NFNHyjkLx_77fLUiZXnL6qyb2jXnBSFd7XxvqmBktYYYuRdW2UgDe5qVaFLcPvjs65R5SBOOXVg7no5EAiWFU\/s1600\/47418_368678346549197_724740498_n.jpeg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjPyzFSiRPskPW1Fm_AEn7wtZfmEIt2_DEYf4SOjb5iKRTvMKKwPw43h4NFNHyjkLx_77fLUiZXnL6qyb2jXnBSFd7XxvqmBktYYYuRdW2UgDe5qVaFLcPvjs65R5SBOOXVg7no5EAiWFU\/s320\/47418_368678346549197_724740498_n.jpeg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgDhpFlkj1AaXLAZWPFdjCJL0tEeLk3oChfUU6wFxqyrj-0ZgXUflDm-_tRG-MWEcocP2KKD3d1ysDOqaDJMacKg1sT5rhUat3m7Szxp0TglRtw0t4xQ3eHrpFXbHFl-g1DmJ0_90xL1sQ\/s1600\/65352_368678356549196_1257195507_n.jpeg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgDhpFlkj1AaXLAZWPFdjCJL0tEeLk3oChfUU6wFxqyrj-0ZgXUflDm-_tRG-MWEcocP2KKD3d1ysDOqaDJMacKg1sT5rhUat3m7Szxp0TglRtw0t4xQ3eHrpFXbHFl-g1DmJ0_90xL1sQ\/s320\/65352_368678356549196_1257195507_n.jpeg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiBZ_id9jL_SN_4-_EhqkJI_W2dW0sZI945IXfhR0zKcVNG_QA6C8sowVQOjZCdsXm0gPy3irRSuO3wEc2uY7aFKNlUBYeCAlVTenhxXnWd-oB-ewkXwPBDbzOJgjwVBdiOlq8JN7QXNAA\/s1600\/69780_368675919882773_228533984_n.jpeg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiBZ_id9jL_SN_4-_EhqkJI_W2dW0sZI945IXfhR0zKcVNG_QA6C8sowVQOjZCdsXm0gPy3irRSuO3wEc2uY7aFKNlUBYeCAlVTenhxXnWd-oB-ewkXwPBDbzOJgjwVBdiOlq8JN7QXNAA\/s320\/69780_368675919882773_228533984_n.jpeg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003C\/div\u003E\n\u003Cbr \/\u003E\nNie  je preto prekvapením, že najstaršie osídlenie pochádza už paleolitu  (nálezy homo neandertalensis) či z\u0026nbsp;neolitu (bukovohorská kultúra). Prvé  opevnenie tam vzniklo v\u0026nbsp;eneolite (bádenská kultúra), na ktoré potom  nadviazali ďalšie kultúry doby bronzovej a\u0026nbsp;určite aj železnej.  Najvýraznejšie osídlenie pochádza z\u0026nbsp;9. - 11. stor., keď bola rozmerná  plošina využívaná ako refúgium. Obdobie raného stredoveku bolo pomerne  nepokojné a\u0026nbsp;často hrozilo nebezpečenstvo. Preto bol Dreveník veľmi  vhodným miestom na úkryt pre miestne slovanské obyvateľstvo, ktoré si na  plošine budovalo obydlia a\u0026nbsp;neskôr aj obranné zariadenia. Prvé zapojenie  hradiska, resp. refúgia, do organizovaného obranného systému je možné  predpokladať za vlády Svätopluka (871 - 894), keď sa Veľká Morava  rozšírila až po stredný tok Hornádu.\u0026nbsp;Obdobie medzi zánikom V. Moravy  a\u0026nbsp;pripojením daného územia k\u0026nbsp;Uhorsku bolo opäť nestabilné a\u0026nbsp;nepokojné,  o\u0026nbsp;čom svedčia najviac zastúpené nálezy práve z 10. - 11. stor. Vznikom  župného systému a\u0026nbsp;iných centier správy, no najmä upokojením politickej  situácie hradisko v\u0026nbsp;priebehu 12. stor. zaniká. Opätovne však mohlo byť  využité počas tatárskeho vpádu, čoho dôkazom sú nálezy aj z\u0026nbsp;13. stor.\u003Cbr \/\u003E\n\u0026nbsp; \u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Ciframe frameborder=\"0\" height=\"350\" marginheight=\"0\" marginwidth=\"0\" scrolling=\"no\" src=\"http:\/\/maps.google.com\/?ie=UTF8\u0026amp;ll=48.982865,20.775232\u0026amp;spn=0.026925,0.055189\u0026amp;t=h\u0026amp;z=14\u0026amp;output=embed\" width=\"425\"\u003E\u003C\/iframe\u003E\u003Cbr \/\u003E\n\u003Csmall\u003E\u003Ca href=\"http:\/\/maps.google.com\/?ie=UTF8\u0026amp;ll=48.982865,20.775232\u0026amp;spn=0.026925,0.055189\u0026amp;t=h\u0026amp;z=14\u0026amp;source=embed\" style=\"color: blue; text-align: left;\"\u003EZväčšiť mapu\u003C\/a\u003E\u003C\/small\u003E\u003Cbr \/\u003E\n\u003Cbr \/\u003E\nVrcholová  plošina pretiahnutého tvaru v smere S-J (1 500 x 800 m) bola zrejme  osídlená z\u0026nbsp;väčšej časti, no samotné hradisko sa nachádzalo na  juhozápadnom cípe. Práve tam boli najvhodnejšie podmienky na výstavbu  obranného zariadenia (presne vymedzená najrovnejšia plocha, ohraničená  takmer zo všetkých strán skalnými stenami dosahujúcimi najväčšie  prevýšenie oproti okoliu v\u0026nbsp;rámci celej kopy). Len úzky pás na  severovýchode, kde sa skalná ostroha pripájala k\u0026nbsp;jadru kopy, nebol  prirodzene chránený. Vznikol tam preto mohutný zemný val, na ktorom  stála zrejme ešte palisáda. V\u0026nbsp;takto ohraničenom areáli sa nachádzali  obytné štruktúry z\u0026nbsp;drevených konštrukcií. Zároveň sa predpokladá, že na  kope Ostrá hora severne od Dreveníka ležalo ďalšie hradisko, ktoré  tvorilo súčasť obrany hlavného hradiska. Svedčia o\u0026nbsp;tom nálezy aj zistený  viditeľný priebeh opevnenia, no poloha bola ťažbou postupne značne  zdeformovaná.\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgm2tUP1_jO1btabzKNzi-YUO-o_athC98ZvgqHC6UIPML7VCHrONPEa-s1gof6anQlXuz21LdfWt2MVUy80r8xEhGPzq7oPDt1ZsAshJkgHnfVmHzZchigPlSR1RYIEMJvaMVn2ngqTYI\/s1600\/374599_182677211815979_100002211037366_400627_510317572_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgm2tUP1_jO1btabzKNzi-YUO-o_athC98ZvgqHC6UIPML7VCHrONPEa-s1gof6anQlXuz21LdfWt2MVUy80r8xEhGPzq7oPDt1ZsAshJkgHnfVmHzZchigPlSR1RYIEMJvaMVn2ngqTYI\/s320\/374599_182677211815979_100002211037366_400627_510317572_n.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhNN83qUQbZbxft9xWAUit52VTv991pthmz_mKhfIxsaY6w_v_TN_HcpwmL2Z2k4hugXgSaHXbKt4EPbXI-04Ykx8g49AzxW4-ual9Z-LaWa5uCoJ8cLSk77-aotQ20HBZEbbowpfT757M\/s1600\/388630_182676641816036_100002211037366_400617_1285627830_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhNN83qUQbZbxft9xWAUit52VTv991pthmz_mKhfIxsaY6w_v_TN_HcpwmL2Z2k4hugXgSaHXbKt4EPbXI-04Ykx8g49AzxW4-ual9Z-LaWa5uCoJ8cLSk77-aotQ20HBZEbbowpfT757M\/s320\/388630_182676641816036_100002211037366_400617_1285627830_n.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEh5c3vQQVgxJ76Afg2Nh1nEAAwEDbfwnO5Ny_Qn70yBiQFiBKRoAVQ-74BiJu-IZWRUNAiEMhvGgO6275afm8B5W_mPakhopxwL1-6FonQSfcw9Pn8U-9nU4VsGsnupAiR2Qy_H5FZHrbQ\/s1600\/391608_182677381815962_100002211037366_400630_1440873201_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEh5c3vQQVgxJ76Afg2Nh1nEAAwEDbfwnO5Ny_Qn70yBiQFiBKRoAVQ-74BiJu-IZWRUNAiEMhvGgO6275afm8B5W_mPakhopxwL1-6FonQSfcw9Pn8U-9nU4VsGsnupAiR2Qy_H5FZHrbQ\/s320\/391608_182677381815962_100002211037366_400630_1440873201_n.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\nNiekoľko fotografií od Svätohája rodnej viery:\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEi1FKG-RlVm9phPGwdJp7yL8tpqKOtrJxCRXEGoh4KGFSnE-GG2m264jkOIIavW6sPgy5YtqPo7b4sID49mhq__HI85_HBqfs-IRx2YL7WTSr_fCXaKuruACwDb9cVA0BxZaA7GUiDSD_8\/s1600\/1016495_10202098940794819_4842289734802316142_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"320\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEi1FKG-RlVm9phPGwdJp7yL8tpqKOtrJxCRXEGoh4KGFSnE-GG2m264jkOIIavW6sPgy5YtqPo7b4sID49mhq__HI85_HBqfs-IRx2YL7WTSr_fCXaKuruACwDb9cVA0BxZaA7GUiDSD_8\/s1600\/1016495_10202098940794819_4842289734802316142_n.jpg\" width=\"240\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiXkt1_t8taPNR1tm19gt4KuldWmO323evXJ5blr64sq5Si33NEf7HzaAhZBI_16OHntUj9Uezi7KpIVc_0gQ555M4QHSTSUg_FP53L4tLKQpcUHfgAhhbJ3OjFuVe3ou4VCuNTit3LqEc\/s1600\/1901397_10202098940474811_7786416224307832761_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiXkt1_t8taPNR1tm19gt4KuldWmO323evXJ5blr64sq5Si33NEf7HzaAhZBI_16OHntUj9Uezi7KpIVc_0gQ555M4QHSTSUg_FP53L4tLKQpcUHfgAhhbJ3OjFuVe3ou4VCuNTit3LqEc\/s1600\/1901397_10202098940474811_7786416224307832761_n.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEj_cxEd1xBflh9EgFJ_h5XVE-RGU84o-gv-tJUztkVGA8vXTotqquMczIzHS5KCi39b6ZY7kWnzUmsvk0MDgsq50XZz4JV-ZuMcOYvWUIjmPYah4r1MotWbgqzcGeyFYDRQ6tmdIf4VL-U\/s1600\/10423937_10202098939274781_4812347795170352622_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEj_cxEd1xBflh9EgFJ_h5XVE-RGU84o-gv-tJUztkVGA8vXTotqquMczIzHS5KCi39b6ZY7kWnzUmsvk0MDgsq50XZz4JV-ZuMcOYvWUIjmPYah4r1MotWbgqzcGeyFYDRQ6tmdIf4VL-U\/s1600\/10423937_10202098939274781_4812347795170352622_n.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEh7GqkBSH29Qp-UQlDH9FRTb8wdc3I7MKeWPFCt0QsXcjQr7bvNzbdGWwNzCn4-MpMi9o-GStpzHfoeBWaQhNh0wRJGZM9igEgj2kave3Yz5CJkzZ_ay_BDnsoUoMM8EwsTKZqP3byr8EY\/s1600\/10599591_10202098939514787_3367032261049637286_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEh7GqkBSH29Qp-UQlDH9FRTb8wdc3I7MKeWPFCt0QsXcjQr7bvNzbdGWwNzCn4-MpMi9o-GStpzHfoeBWaQhNh0wRJGZM9igEgj2kave3Yz5CJkzZ_ay_BDnsoUoMM8EwsTKZqP3byr8EY\/s1600\/10599591_10202098939514787_3367032261049637286_n.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Ch3\u003E\nDnešný stav lokality\u003C\/h3\u003E\nV\u0026nbsp;súčasnosti sa lokalita hlavného hradiska nachádza v\u0026nbsp;katastri  Spišského Pohradia, na hranici katastra Žehry. Ide o\u0026nbsp;juhozápadný výbežok  z\u0026nbsp;centrálnej časti Dreveníka (560 - 570 m n. m.), kde lokalitu  ohraničujú skalné zrázy a\u0026nbsp;na severovýchode zachovaný mohutný valový  násyp. Zemný skalný val je situovaný v\u0026nbsp;smere SZ-JJV, jeho dĺžka je 60 m  a\u0026nbsp;výška miestami aj 2 m. Za posledných tisíc rokov bol značne prirodzene  zdeštruovaný, preto\u0026nbsp;jeho pôvodná výška bola minimálne dvakrát väčšia  ako súčasná. Z\u0026nbsp;lokality pochádzajú rôzne nálezy svedčiace o\u0026nbsp;funkcii  hradiska v\u0026nbsp;9. - 11. stor. Výskumy tam realizoval už J. Neustupný v\u0026nbsp;r.  1932, potom V. Budinský-Krička, V. Furmánek či M. Slivka.\u003Cbr \/\u003E\n\u003Cbr \/\u003E\nAutor článku: Dominik Sabol. Prevzaté so súhlasom autora zo stránky \u003C\/div\u003E\n\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u0026nbsp;\u003Ca href=\"http:\/\/korzar.sme.sk\/c\/5128105\/patranie-po-hradoch-spisske-podhradie-drevenik.html#ixzz1T7OOaon9\" style=\"color: #003399;\"\u003Ehttp:\/\/korzar.sme.sk\/c\/5128105\/patranie-po-hradoch-spisske-podhradie-drevenik.html#ixzz1T7OOaon9\u003C\/a\u003E\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\nFoto: Siváci Košice november 2012\u003Cbr \/\u003E\nwww.travel.sk\u003C\/div\u003E\n"},"link":[{"rel":"replies","type":"application/atom+xml","href":"http:\/\/www.hradiska.sk\/feeds\/5507753766734512788\/comments\/default","title":"Zverejniť komentáre"},{"rel":"replies","type":"text/html","href":"http:\/\/www.hradiska.sk\/2011\/07\/drevenik-slovanske-hradisko-v-tieni.html#comment-form","title":"0 komentárov"},{"rel":"edit","type":"application/atom+xml","href":"http:\/\/www.blogger.com\/feeds\/6818054921907446479\/posts\/default\/5507753766734512788"},{"rel":"self","type":"application/atom+xml","href":"http:\/\/www.blogger.com\/feeds\/6818054921907446479\/posts\/default\/5507753766734512788"},{"rel":"alternate","type":"text/html","href":"http:\/\/www.hradiska.sk\/2011\/07\/drevenik-slovanske-hradisko-v-tieni.html","title":"Dreveník - Slovanské hradisko v tieni Spišského hradu"}],"author":[{"name":{"$t":"Orgon"},"uri":{"$t":"http:\/\/www.blogger.com\/profile\/01396912608531297025"},"email":{"$t":"noreply@blogger.com"},"gd$image":{"rel":"http://schemas.google.com/g/2005#thumbnail","width":"32","height":"32","src":"\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEjRf79q2mlg3o6hsyWbYMCCgv1WaA6pM0mtkWB0QdJ76W64emXoS0lwpSlUw9K5iinuoAVrX4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY\/s220\/SH+Kruh+s+dlznom1.JPG"}}],"media$thumbnail":{"xmlns$media":"http://search.yahoo.com/mrss/","url":"https:\/\/img.youtube.com\/vi\/7cJT2cMQUls\/default.jpg","height":"72","width":"72"},"thr$total":{"$t":"0"}}]}}