RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY/s220/SH+Kruh+s+dlznom1.JPG"}}],"generator":{"version":"7.00","uri":"http://www.blogger.com","$t":"Blogger"},"openSearch$startIndex":{"$t":"1"},"openSearch$itemsPerPage":{"$t":"25"},"entry":[{"id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479.post-1169323134002611145"},"published":{"$t":"2015-03-30T19:27:00.001+02:00"},"updated":{"$t":"2015-03-30T19:35:19.523+02:00"},"title":{"type":"text","$t":"Tak nám zas zamlčiavajú dejiny..."},"content":{"type":"html","$t":"<div style=\"text-align: justify;\">\n<span style=\"font-size: large;\">Pred časom sa na pultoch slovenských kníhkupectiev objavila kniha s názvom&nbsp;<b>Tajné dejiny Slovenska, Slovenov a Sloveniek </b>od autora Oskara Cvengroscha, ktorá vzbudila pozornosť veľkého množstva záujemcov o naše dejiny. Po jej \"letmom\" prelistovaní, trvajúcom asi hodinu som ju zhrozený odložil naspäť do poličky, avšak mal som chuť ju umiestniť do oddelenia fantasy literatúry. Toto nemôže autor myslieť vážne!</span></div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div style=\"text-align: justify;\">\n<span style=\"font-size: large;\">Keďže však nie som historik ani archeológ, nedovolím si na knihu písať recenziu. O to viac ma dnes potešilo, keď som na stránkach portálu HISTORYWEB, s ktorým už dlhšie spolupracujeme objavil recenziu odborníkov (archeológov a historikov), ktorí knihu celú prečítali, za čo im patrí moja úprimná sústrasť. Možno Vám táto recenzia ušetrí zbytočne vyhodené ťažko zarobené peniaze ....&nbsp;</span></div>\n<div style=\"text-align: justify;\">\n<i><span style=\"font-size: large;\"><br /></span></i></div>\n<div style=\"text-align: justify;\">\n<i><span style=\"font-size: large;\"><b>\"Aká je kniha Tajné dejiny Slovenska, Slovenov a Sloveniek?</b> Keď som začal pracovať na tejto recenzii, nevedel som, pravdupovediac, do čoho sa púšťam a kde skončím. Ešte plný optimizmu som pred vlastným čítaním oslovil autora, aby mi zaslal svoje životopisné údaje, pretože v knihe žiadne nie sú a bolo by vhodné vedieť, čiu knihu idem recenzovať. Prišla mi jednoriadková odpoveď, že autor je odo mňa trochu starší Prešovčan s technickým vzdelaním. Neskôr som zistil, že posledné dve slová tejto odpovede predstavujú značne široký pojem.</span></i></div>\n<div style=\"text-align: justify;\">\n<i><br /></i></div>\n<div class=\"separator\" style=\"clear: both; text-align: center;\">\n<a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEh8nAwtBtlk__iiiLVez5YLgODPrfpNLdE5wea6fNxwmtDpIdDRfZcuFAROWVoZB43UPurfkd2ZvFpXuWXnKIu5psEBRLTGTZ_jzlBWZIsmT3BwQPTV7MOuzTmX_DjoS5nvjOojJgznQUk/s1600/cvengros%CC%8C.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"><img border=\"0\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEh8nAwtBtlk__iiiLVez5YLgODPrfpNLdE5wea6fNxwmtDpIdDRfZcuFAROWVoZB43UPurfkd2ZvFpXuWXnKIu5psEBRLTGTZ_jzlBWZIsmT3BwQPTV7MOuzTmX_DjoS5nvjOojJgznQUk/s1600/cvengros%CC%8C.jpg\" height=\"320\" width=\"217\" /></a></div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div style=\"text-align: justify;\">\n<i><span style=\"font-size: large;\">Absencia akýchkoľvek údajov o autorovi má svoj význam. Nejde o to, že by sa robil tajomným. Ale keď<b> sa z tejto knihy dozvedia Arabi, že Alah/ch je vlastne Valach a že aj Arabi sú Slovania</b>, určite naňho vyhlásia fatwu za urážku viery. Trocha málo originálny spôsob, ako sa presláviť.</span></i></div>\n<div style=\"text-align: justify;\">\n<i><span style=\"font-size: large;\"><br /></span></i></div>\n<div style=\"text-align: justify;\">\n<i><span style=\"font-size: large;\">Knihu som čítal veľmi pozorne, písal som si poznámky a podčiarkoval celé pasáže textu. Po prečítaní som ešte mesiac premýšľal, čo napíšem, a aj som niekoľkokrát rozpačito začal.\"</span></i></div>\n<div style=\"text-align: justify;\">\n<span style=\"font-size: large;\"><br /></span></div>\n<div style=\"text-align: justify;\">\n<span style=\"font-size: large;\"><a href=\"http://historyweb.dennikn.sk/clanky/detail/tak-nam-zas-zamlciavaju-dejiny#.VRmCI5OsUvJ\" target=\"_blank\">Pokračovanie článku si prečítajte na tejto adrese : &nbsp;HISTORYWEB</a></span></div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div style=\"text-align: justify;\">\n<span style=\"font-size: large;\">Prosím, neverte všetkým hlúpostiam iba preto, že vytvárajú pozitívny obraz o Slovanoch. Ak ten obraz nemá žiaden reálny podklad, klameme sami seba.&nbsp;</span></div>\n<div style=\"text-align: justify;\">\n<span style=\"font-size: large;\"><br /></span></div>\n<div style=\"text-align: justify;\">\n<span style=\"font-size: large;\">Heslo našej stránky znie: <b><i>\"Buďme hrdí na naše dejiny. Máme na to mnoho dôvodov\"</i></b>&nbsp;Možno je načase, aby sme toto naše motto mierne doplnili o dovetok: <b><i>\"A nemusíme si ich vymýšľať\"&nbsp;</i></b></span><br />\n<span style=\"font-size: large;\"><b><i><br /></i></b></span>\n<span style=\"font-size: large;\">Neskromne si myslím, že náš portál www.hradiska.sk sa snaží robiť dosť veľa pre znovuobjavovanie a popularizáciu našej slávnej slovanskej histórie. A zaobídeme sa pri tom aj bez nezmyselných fantasmagórií.&nbsp;</span></div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div style=\"text-align: justify;\">\n<span style=\"font-size: large;\">Orgoň</span></div>\n"},"link":[{"rel":"replies","type":"application/atom+xml","href":"http://www.hradiska.sk/feeds/1169323134002611145/comments/default","title":"Zverejniť komentáre"},{"rel":"replies","type":"text/html","href":"http://www.hradiska.sk/2015/03/tak-nam-zas-zamlciavaju-dejiny.html#comment-form","title":"5 komentárov"},{"rel":"edit","type":"application/atom+xml","href":"http://www.blogger.com/feeds/6818054921907446479/posts/default/1169323134002611145"},{"rel":"self","type":"application/atom+xml","href":"http://www.blogger.com/feeds/6818054921907446479/posts/default/1169323134002611145"},{"rel":"alternate","type":"text/html","href":"http://www.hradiska.sk/2015/03/tak-nam-zas-zamlciavaju-dejiny.html","title":"Tak nám zas zamlčiavajú dejiny..."}],"author":[{"name":{"$t":"Orgon"},"uri":{"$t":"http://www.blogger.com/profile/01396912608531297025"},"email":{"$t":"noreply@blogger.com"},"gd$image":{"rel":"http://schemas.google.com/g/2005#thumbnail","width":"32","height":"32","src":"//blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjRf79q2mlg3o6hsyWbYMCCgv1WaA6pM0mtkWB0QdJ76W64emXoS0lwpSlUw9K5iinuoAVrX4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY/s220/SH+Kruh+s+dlznom1.JPG"}}],"media$thumbnail":{"xmlns$media":"http://search.yahoo.com/mrss/","url":"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEh8nAwtBtlk__iiiLVez5YLgODPrfpNLdE5wea6fNxwmtDpIdDRfZcuFAROWVoZB43UPurfkd2ZvFpXuWXnKIu5psEBRLTGTZ_jzlBWZIsmT3BwQPTV7MOuzTmX_DjoS5nvjOojJgznQUk/s72-c/cvengros%CC%8C.jpg","height":"72","width":"72"},"thr$total":{"$t":"5"}}]}}