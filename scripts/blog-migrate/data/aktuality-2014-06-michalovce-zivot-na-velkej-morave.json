rX4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY/s220/SH+Kruh+s+dlznom1.JPG"}}],"generator":{"version":"7.00","uri":"http://www.blogger.com","$t":"Blogger"},"openSearch$startIndex":{"$t":"1"},"openSearch$itemsPerPage":{"$t":"25"},"entry":[{"id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479.post-4908902556885411059"},"published":{"$t":"2014-06-30T21:40:00.001+02:00"},"updated":{"$t":"2014-06-30T21:40:22.762+02:00"},"title":{"type":"text","$t":"Michalovce - Život na Veľkej Morave"},"content":{"type":"html","$t":"<div style=\"text-align: justify;\">\nZemplínske múzeum v Michalovciach zorganizovalo v sobotu 28.6.2014 veľmi zaujímavú akciu s názvom Život na Veľkej Morave. V areáli múzea tak návštevníci okrem zrekonštruovanej slovanskej zemnice, ktorá bola postavená minulý rok, mohli aspoň na pár hodín vyskúšať doslova na vlastnej koži, ako sa žilo našim slovanským predkom v období Veľkej Moravy. Na úvod sa v michalovskej rotunde konala svätá omša s prvkami staroslovienskej liturgie.</div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div class=\"separator\" style=\"clear: both; text-align: center;\">\n<a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgZvNWCJ4ix0_HdQfRWtKV7jadmfxtddyU2bp4m1e4mqx-b7ilh3s7wY0DQ1daB9szUnhDCzh2ptFEkHs1kD7QH-WgKXmBRd7-B0ufzf5Y9x716uFrx_QsQU6NifoBzmUSMvZNB-iH-sm0/s1600/10410432_4354161550062_34823410366812812_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"><img border=\"0\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgZvNWCJ4ix0_HdQfRWtKV7jadmfxtddyU2bp4m1e4mqx-b7ilh3s7wY0DQ1daB9szUnhDCzh2ptFEkHs1kD7QH-WgKXmBRd7-B0ufzf5Y9x716uFrx_QsQU6NifoBzmUSMvZNB-iH-sm0/s1600/10410432_4354161550062_34823410366812812_n.jpg\" height=\"320\" width=\"226\" /></a></div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div style=\"text-align: justify;\">\nVďaka &nbsp;účinkujúcim, ktorých jadro tvorila skupina Siváci z Košíc, ale viacerí prišli zo vzdialených kútov republiky, sme mohli stretnúť slovanských bojovníkov, krásne slovanské devy, nebezpečných kočovníkov s lukmi, žreca, ale aj viacerých remeselníkov a hudobníkov. Videli sme ako sa &nbsp;v 9. storočí mlelo obilie, ako sa z neho vyrábali chutné chlebové placky a mohli sme vyskúšať, ako chutili. Návštevníci si mohli vyskúšať streľbu z luku, výrobu keramiky a pre deti bolo tiež pripravených množstvo lákavých atrakcií. Bojovníci nám predviedli ukážky bojov v slovanskom období a scénky zo života. Svoje umenie predviedol aj sokoliar.&nbsp;</div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div style=\"text-align: justify;\">\nPrinášame Vám krátku fotoreportáž z tejto akcie a veríme, že budúci rok sa tu zídeme opäť.</div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<table align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"><tbody>\n<tr><td style=\"text-align: center;\"><a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjY_OHKBaNmUHUbm_jIfxGh1gNYcTQqJ0eMpmuFSGiAnmXZ47kSDg8rU23H83y5vPHhsHUUZrAeObbxKvB-40sby390LLKAjcbiY1ABGKdyEOvde5HsRZ4jTi1XBVz11RnvVnH0FOweWbk/s1600/IMG_9859.JPG\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"><img border=\"0\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjY_OHKBaNmUHUbm_jIfxGh1gNYcTQqJ0eMpmuFSGiAnmXZ47kSDg8rU23H83y5vPHhsHUUZrAeObbxKvB-40sby390LLKAjcbiY1ABGKdyEOvde5HsRZ4jTi1XBVz11RnvVnH0FOweWbk/s1600/IMG_9859.JPG\" height=\"213\" width=\"320\" /></a></td></tr>\n<tr><td class=\"tr-caption\" style=\"text-align: center;\">Michalovská rotunda</td></tr>\n</tbody></table>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div class=\"separator\" style=\"clear: both; text-align: center;\">\n<a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEgSi0ttcck-rq_qmABEf_PCIhuZ5xsy7BIFse2tRT-OcnEjDzjwtGFQk9qCNZXDDM1ry44