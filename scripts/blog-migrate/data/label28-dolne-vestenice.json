WbYMCCgv1WaA6pM0mtkWB0QdJ76W64emXoS0lwpSlUw9K5iinuoAVrX4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY\/s220\/SH+Kruh+s+dlznom1.JPG"}}],"generator":{"version":"7.00","uri":"http://www.blogger.com","$t":"Blogger"},"openSearch$totalResults":{"$t":"1"},"openSearch$startIndex":{"$t":"1"},"openSearch$itemsPerPage":{"$t":"5"},"entry":[{"id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479.post-4194074486566808618"},"published":{"$t":"2018-10-09T22:30:00.000+02:00"},"updated":{"$t":"2020-03-28T23:23:55.845+01:00"},"category":[{"scheme":"http://www.blogger.com/atom/ns#","term":"Dolné Vestenice"}],"title":{"type":"text","$t":"Dolné Vestenice - Slovanské hradisko"},"content":{"type":"html","$t":"\u003Cdiv style=\"margin-bottom: 0cm; text-align: justify;\"\u003E\nPred niekoľkými rokmi archeológovia objavili doposiaľ neznáme slovanské hradisko v obci Dolné Vestenice. Následne tu zrealizoval AU SAV archeologický výskum pod vedením Karola Pietu, na ktorom sa zúčastnilo aj OZ Hradiská. Hradisko sa nachádza v ťažko dostupnom teréne na rozhraní Dolných Vesteníc a Uhrovského Podhradia nad údolím Hradištnica.\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgLAI_2kXEJazKhC5kqMAOTWZwEIyE1rWEDPxvK9UIaHS2a2uAynbeQOTOzvilc9wAYLuqlIhkshFtFkYMxqEB_SwZmYoioWSKQrMCDRwdE5Hpgs0ieVUkzYuwlpg6nRv-twFLwgUgFpin7\/s1600\/LIDAR+z+Bojnej+2.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"318\" data-original-width=\"346\" height=\"294\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgLAI_2kXEJazKhC5kqMAOTWZwEIyE1rWEDPxvK9UIaHS2a2uAynbeQOTOzvilc9wAYLuqlIhkshFtFkYMxqEB_SwZmYoioWSKQrMCDRwdE5Hpgs0ieVUkzYuwlpg6nRv-twFLwgUgFpin7\/s320\/LIDAR+z+Bojnej+2.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003ELidarový záber hradiska (z knihy Bojná 2)\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cbr \/\u003E\nMá podlhovastý tvar a zaberá plochu približne 0,5 ha. Jeho najstaršie osídlenie je doložené v strednej dobe laténskej a v dobe sťahovania národov. Najväčší a najdôležitejší súbor nálezov však pochádza z včasného stredoveku, z 9.-10. stor., to znamená z obdobia existencie Veľkej Moravy.\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiWGB3qx2LZP2vjqXC2hW-g6idHirmDzT0fzMrZB_N1ffUpmf1K1VTipldJa6qGsvK55gyTtm2vpMivttvZneVLGQlL8-wPzSBkXTY5UktYJ218YBxGnpq_kDEkwFFw9utLCzkLIz2-8TCH\/s1600\/48393263_384064458824108_7609739758457061376_n.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" data-original-height=\"696\" data-original-width=\"955\" height=\"233\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiWGB3qx2LZP2vjqXC2hW-g6idHirmDzT0fzMrZB_N1ffUpmf1K1VTipldJa6qGsvK55gyTtm2vpMivttvZneVLGQlL8-wPzSBkXTY5UktYJ218YBxGnpq_kDEkwFFw9utLCzkLIz2-8TCH\/s320\/48393263_384064458824108_7609739758457061376_n.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003C\/div\u003E\n\u003Cdiv style=\"margin-bottom: 0cm; text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEh8w2oXUq6ho4NUtRiTyuXpbT1f_zQv4c17iqpBU4xBywQHo6yldma1obzbUW1-HdEfrIYGDqyzGfNQrzONmjImdqgzzJdmWZJvHd-WhkfVhtC3SeWZXP1al0ls6-vH7DQFIPrxP1Oh2Xpk\/s1600\/DJI_0010.JPG\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"1200\" data-original-width=\"1600\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEh8w2oXUq6ho4NUtRiTyuXpbT1f_zQv4c17iqpBU4xBywQHo6yldma1obzbUW1-HdEfrIYGDqyzGfNQrzONmjImdqgzzJdmWZJvHd-WhkfVhtC3SeWZXP1al0ls6-vH7DQFIPrxP1Oh2Xpk\/s320\/DJI_0010.JPG\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EPohľad na mohutný val hradiska, ktorý sa nachádza na severnej strane\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cdiv style=\"margin-bottom: 0cm; text-align: justify;\"\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiHQMq77947XIYRU4796eiSvM6SU_YTRBXt7KLgvxGjevrQQ8xkNvbrouzONPWSo0SMP2iHY5nQJw4qpGHHxfZk05yH2nITtLe53SH8TKxDRY649vckytjJIp_2hFs1WF9mQFjy3wv-XtyZ\/s1600\/Tomas+Kytka.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"960\" data-original-width=\"1280\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEiHQMq77947XIYRU4796eiSvM6SU_YTRBXt7KLgvxGjevrQQ8xkNvbrouzONPWSo0SMP2iHY5nQJw4qpGHHxfZk05yH2nITtLe53SH8TKxDRY649vckytjJIp_2hFs1WF9mQFjy3wv-XtyZ\/s320\/Tomas+Kytka.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EPohľad na opevnenie hradiska a časť vnútornej plochy. Autor Tomáš Kytka\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv style=\"margin-bottom: 0cm; text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv style=\"margin-bottom: 0cm; text-align: justify;\"\u003E\nSvahy hradiska sú veľmi strmé a celá poloha vyzerá takmer ako stolová hora. Pohodlný prístup bol iba čiastočne zo severu, kde naši predkovia vybudovali mohutný val. V týchto častiach bol zrejme aj pôvodný vstup na hradisko. V ostatných častiach hradiska postačovala ako opevnenie iba drevená palisáda. \u003C\/div\u003E\n\u003Cdiv\u003E\n\u003Cbr \/\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgLWfy2xt1IKrqdQ9L9VbdU3_EkkyAw4Di0ZNj6D80Lt5kWCw633AVWiRxSiLf5x2p-uP2LSG1yotWzHSFoXfHI3v4hJF9kh1v2koNERIEq1fxW7H875AZT8jJOXnu3aP_OoNRjaNM3oeNZ\/s1600\/Plocha.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"720\" data-original-width=\"960\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEgLWfy2xt1IKrqdQ9L9VbdU3_EkkyAw4Di0ZNj6D80Lt5kWCw633AVWiRxSiLf5x2p-uP2LSG1yotWzHSFoXfHI3v4hJF9kh1v2koNERIEq1fxW7H875AZT8jJOXnu3aP_OoNRjaNM3oeNZ\/s320\/Plocha.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003EVnútorná plocha hradiska\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cbr \/\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEj1C8JVYJLZb5xTcJFa4-BNcdTsm5SfCSXe8dsxYbu48ZfMe8FrU5oANM2duKX5rJULC7v-xyDBsT0R5rD0fCASbE6jkuyz0GFKO5G06N7J0AmTn2xDzmXxZ9GRBHOWad774rysxrJiioyu\/s1600\/vlnovka.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"720\" data-original-width=\"960\" height=\"240\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEj1C8JVYJLZb5xTcJFa4-BNcdTsm5SfCSXe8dsxYbu48ZfMe8FrU5oANM2duKX5rJULC7v-xyDBsT0R5rD0fCASbE6jkuyz0GFKO5G06N7J0AmTn2xDzmXxZ9GRBHOWad774rysxrJiioyu\/s320\/vlnovka.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003ESlovanský črep\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cbr \/\u003E\n\u003Cbr \/\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\nMatej Ruttkay v knihe Boná 2 uvádza, že sa tu zistili stopy po miestnej výrobe rôznych remeselníkov – šperkárov, kovolejárov, kováčov a pod. Dokladá to najmä veľký počet polotovarov. Karol Pieta k tomu dodáva, že je tu v rámci intenzívnej kováčskej výroby doložená napríklad výroba sekerovitých hrivien. K najvýraznejším nálezom z priestoru hradiska patria ostrohy s háčikmi, fragmenty krúžkovej zbroje, olovené ingoty a modely náušníc, fragment oloveného kríža, železné ostrohy s dlhým členeným bodcom, hroty šípov. Okrem kovových predmetov sa našlo množstvo typickej slovanskej keramiky s vlnovkovou výzdobou a časti kamenných žarnovov. Situácia by mohla naznačovať zánik hradiska na prelome 9. a 10. stor.\u0026nbsp;\u0026nbsp;\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv class=\"separator\" style=\"clear: both; text-align: center;\"\u003E\n\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEi9XvQyVPjHYNENJAMlVXBm7TLYDYEWPJCnpMqI-AEHfkkxXpjGmxe3hwhkAEjovf1W17pVIyY7RTlhiwMw-uo68Cxwch8iQR364A91BavUpKBHbunfoVeT0ZKFIq9WXGzAzgOlqy4g7vUN\/s1600\/n%25C3%25A1lezy2.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"\u003E\u003Cimg border=\"0\" data-original-height=\"863\" data-original-width=\"633\" height=\"320\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEi9XvQyVPjHYNENJAMlVXBm7TLYDYEWPJCnpMqI-AEHfkkxXpjGmxe3hwhkAEjovf1W17pVIyY7RTlhiwMw-uo68Cxwch8iQR364A91BavUpKBHbunfoVeT0ZKFIq9WXGzAzgOlqy4g7vUN\/s320\/n%25C3%25A1lezy2.jpg\" width=\"234\" \/\u003E\u003C\/a\u003E\u003C\/div\u003E\n\u003Cbr \/\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhuPQ7jl9adt9Vl1I6dqMMPAFOODyN5sUxUm68uxeMxFlnV_u-ZH4UreJTinDBR6O9B1TG_1E3cOgIEI-oGxqpKTLfRqLTopoKcP3_2rpgmhozI9ey5ZUm95D24kEqf_bZQs2UEhlaS3f27\/s1600\/N%25C3%25A1lezy+1.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"284\" data-original-width=\"563\" height=\"161\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhuPQ7jl9adt9Vl1I6dqMMPAFOODyN5sUxUm68uxeMxFlnV_u-ZH4UreJTinDBR6O9B1TG_1E3cOgIEI-oGxqpKTLfRqLTopoKcP3_2rpgmhozI9ey5ZUm95D24kEqf_bZQs2UEhlaS3f27\/s320\/N%25C3%25A1lezy+1.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\"\u003ENálezy z Vesteníc\u003C\/td\u003E\u003C\/tr\u003E\n\u003C\/tbody\u003E\u003C\/table\u003E\n\u003Cbr \/\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\nPri úpätí hradiska  aj v širšom okolí sa našlo viac ojedinelých nálezov i depotov hrivien a náradia. Podobne ako v priestore Bojnej aj tu sa osídlenie sústreďuje v horských polohách, kde sa pomerne vysoko položené horské hrebene využívali ako komunikačné línie. Zdá sa, že príčinou obsadzovania výšinných polôh na Nitriansku bola, podobne ako v iných historických etapách, nepokojná doba a potreba zabezpečenia komunít pred náhlymi prepadmi, možnože v spojení s kontrolou strategických horských prechodov a s využívaním miestneho rudného bohatstva i d'alších prírodných zdrojov, ktoré je v oblasti hornej Nitry doložené aj archeologicky.\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\nOrgoň\u003C\/div\u003E\n\u003C\/div\u003E\n\u003Cdiv style=\"text-align: justify;\"\u003E\n\u003Cbr \/\u003E\n\u003Ctable align=\"center\" cellpadding=\"0\" cellspacing=\"0\" class=\"tr-caption-container\" style=\"margin-left: auto; margin-right: auto; text-align: center;\"\u003E\u003Ctbody\u003E\n\u003Ctr\u003E\u003Ctd style=\"text-align: center;\"\u003E\u003Ca href=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhIllRMOCmyWEtzsmClinTppovLKJKO6uJwsiyqNWK7a7Tr4rXShKEBGRtlC9KRDKxxaAkYp4rDsGCYLLKbkDxD3Bxq-ab4Gs7snTigFD-xmsdgPmkOA9aw_r0pzKyj72Nh_ruvDYeqwUP1\/s1600\/dron.jpg\" imageanchor=\"1\" style=\"margin-left: auto; margin-right: auto;\"\u003E\u003Cimg border=\"0\" data-original-height=\"900\" data-original-width=\"1600\" height=\"180\" src=\"https:\/\/blogger.googleusercontent.com\/img\/b\/R29vZ2xl\/AVvXsEhIllRMOCmyWEtzsmClinTppovLKJKO6uJwsiyqNWK7a7Tr4rXShKEBGRtlC9KRDKxxaAkYp4rDsGCYLLKbkDxD3Bxq-ab4Gs7snTigFD-xmsdgPmkOA9aw_r0pzKyj72Nh_ruvDYeqwUP1\/s320\/dron.jpg\" width=\"320\" \/\u003E\u003C\/a\u003E\u003C\/td\u003E\u003C\/tr\u003E\n\u003Ctr\u003E\u003Ctd class=\"tr-caption\" style=\"text-align: center;\