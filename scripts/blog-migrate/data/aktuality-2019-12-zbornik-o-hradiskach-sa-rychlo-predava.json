nuoAVrX4RwIXY0RoOkY_QRl8Yy2oMkJAodsY_W7_GnMHXspVw3fuuBpiYA7JlSOlY/s220/SH+Kruh+s+dlznom1.JPG"}}],"generator":{"version":"7.00","uri":"http://www.blogger.com","$t":"Blogger"},"openSearch$startIndex":{"$t":"1"},"openSearch$itemsPerPage":{"$t":"25"},"entry":[{"id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479.post-8764072461575391662"},"published":{"$t":"2019-12-11T13:34:00.002+01:00"},"updated":{"$t":"2020-01-19T20:16:22.561+01:00"},"title":{"type":"text","$t":"Zborník o hradiskách sa rýchlo predáva"},"content":{"type":"html","$t":"<div style=\"text-align: justify;\">\nV novembri sme vydali náš dlho očakávaný zborník Hradiská - Svedkovia dávnych čias 2. Dali sme vytlačiť 700 kusov, pričom ku dnešnému dňu už zostáva menej ako 200 výtlačkov. Preto odporúčam každému, kto o zborník má záujem, aby si ho objednal čo najskôr.&nbsp;</div>\n<br />\n<div style=\"text-align: justify;\">\nPreto tí, čo máte záujem, neváhajte a <b>pošlite objednávku</b> na adresu <b>zbornik.hradiska@gmail.com</b>. Pripomínam že prvý zborník sa v roku 2016 vypredal do jedného mesiaca a žiadna dotlač nie je v pláne.</div>\n<div style=\"text-align: justify;\">\n<br /></div>\n<div class=\"separator\" style=\"clear: both; text-align: center;\">\n<a href=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjETkVqgYWW7iye118GPuS1tngW-n9sIFnoI_1gv8jEkcJUO6KXyl-qrdCLw8L3e6t2sibjkNYNfBfhH9P5xoPG-vbFm7zonaPY-uiHsLnfEK-2vGooey4jEzsFOUJOwqtg_STTYAVGEwDs/s1600/Obal+s+cenou.jpg\" imageanchor=\"1\" style=\"margin-left: 1em; margin-right: 1em;\"><img border=\"0\" data-original-height=\"1037\" data-original-width=\"1440\" height=\"230\" src=\"https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEjETkVqgYWW7iye118GPuS1tngW-n9sIFnoI_1gv8jEkcJUO6KXyl-qrdCLw8L3e6t2sibjkNYNfBfhH9P5xoPG-vbFm7zonaPY-uiHsLnfEK-2vGooey4jEzsFOUJOwqtg_STTYAVGEwDs/s320/Obal+s+cenou.jpg\" width=\"320\" /></a></div>\n<br />\n<div class=\"separator\" style=\"clear: both; text-align: center;\">\n<a href=\"https://blogger.googleu