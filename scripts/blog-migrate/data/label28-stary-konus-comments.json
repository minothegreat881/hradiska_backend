 a s├║ devastovan├® ┼źa┼Škou drev├Īrskou technikou.─Äakujem Orgo┼łovi za t├║to str├Īnku a v┼Īetk├Įm ─Źo tu prispievaj├║. Martin z MI"},"link":[{"rel":"edit","type":"application/atom+xml","href":"http:\/\/www.blogger.com\/feeds\/6818054921907446479\/7432743519277329387\/comments\/default\/4981461168278047509"},{"rel":"self","type":"application/atom+xml","href":"http:\/\/www.blogger.com\/feeds\/6818054921907446479\/7432743519277329387\/comments\/default\/4981461168278047509"},{"rel":"alternate","type":"text/html","href":"http:\/\/www.hradiska.sk\/2013\/07\/stary-konus.html?showComment=1459853424370#c4981461168278047509","title":""},{"rel":"related","type":"application/atom+xml","href":"http:\/\/www.blogger.com\/feeds\/6818054921907446479\/7432743519277329387\/comments\/default\/6786343569644966894"}],"author":[{"name":{"$t":"Anonymous"},"email":{"$t":"noreply@blogger.com"},"gd$image":{"rel":"http://schemas.google.com/g/2005#thumbnail","width":"16","height":"16","src":"https:\/\/img1.blogblog.com\/img\/blank.gif"}}],"thr$in-reply-to":{"xmlns$thr":"http://purl.org/syndication/thread/1.0","href":"http:\/\/www.hradiska.sk\/2013\/07\/stary-konus.html","ref":"tag:blogger.com,1999:blog-6818054921907446479.post-7432743519277329387","source":"http://www.blogger.com/feeds/6818054921907446479/posts/default/7432743519277329387","type":"text/html"},"gd$extendedProperty":[{"name":"blogger.itemClass","value":"pid-1346171598"},{"name":"blogger.displayTime","value":"5. apr├Łla 2016 o 12:50"}]},{"id":{"$t":"tag:blogger.com,1999:blog-6818054921907446479.post-7522640752140462012"},"published":{"$t":"2016-04-03T12:32:52.541+02:00"},"updated":{"$t":"2016-04-03T12:32:52.541+02:00"},"title":{"type":"text","$t":"Jaro,po┼Īli mi to na orgon333@gmail.com a ja to sem..."},"content":{"type":"html","$t":"Jaro,po┼Īli mi to na orgon333@gmail.com a ja to sem velmi rad pridam. Orgon"},"link":[{"rel":"edit","type":"application/atom+xml","href":"http:\/\/www.blogger.com\/feeds\/6818054921907446479\/74327